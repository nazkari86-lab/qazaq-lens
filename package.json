{
  "name": "qazaq-lens",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node scripts/generate-precache.mjs",
    "preview": "astro preview",
    "check": "astro check && tsc -p tsconfig.functions.json --noEmit",
    "pages:dev": "npm run build && wrangler pages dev dist",
    "og": "python3 scripts/make_og_images.py",
    "qa": "npm run check && npm run audit:function && npm run audit:content && npm run audit:images && npm run build && node scripts/audit-build.mjs",
    "audit:build": "node scripts/audit-build.mjs",
    "audit:links": "node scripts/check-external-links.mjs",
    "audit:content": "node scripts/audit-content-length.mjs",
    "audit:images": "node scripts/audit-images.mjs",
    "audit:function": "NODE_NO_WARNINGS=1 node scripts/audit-function.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.3",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^7.1.1",
    "scrollama": "^3.2.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@cloudflare/workers-types": "^5.20260719.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.112.0"
  }
}
