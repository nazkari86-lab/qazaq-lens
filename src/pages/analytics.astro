---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getVisibleMyths } from "../lib/content";

const myths = await getVisibleMyths();
const claims = myths.reduce((total, myth) => total + myth.data.claims.length, 0);
const sources = myths.reduce((total, myth) => total + myth.data.sources.length, 0);
const verdicts = myths.reduce<Record<string, number>>((all, myth) => { all[myth.data.verdict] = (all[myth.data.verdict] ?? 0) + 1; return all; }, {});
const reviewed = myths.filter((myth) => myth.data.publicationStatus === "reviewed").length;
const analyticsEnabled = Boolean(import.meta.env.PUBLIC_CF_WEB_ANALYTICS_TOKEN);
const label = (value: string) => value.replaceAll("-", " ");
---
<BaseLayout title="Analytics dashboard" description="Internal Qazaq Lens measurement dashboard." noindex={true}>
  <main class="wrap-wide page-hero analytics-page">
    <p class="eyebrow">Internal dashboard</p>
    <h1>Measure the work, not the reader.</h1>
    <p class="lead">Editorial and product health in one place. Visitor analytics remain aggregated and privacy-friendly.</p>

    <section class="analytics-status card" aria-labelledby="analytics-status-title">
      <div><p class="eyebrow">Visitor analytics</p><h2 id="analytics-status-title">{analyticsEnabled ? "Cloudflare Web Analytics enabled" : "Waiting for Cloudflare token"}</h2><p>{analyticsEnabled ? "Aggregated page views and referrers are available in Cloudflare Web Analytics." : "No visitor numbers are shown until the maintainer configures PUBLIC_CF_WEB_ANALYTICS_TOKEN. This prevents invented or misleading statistics."}</p></div>
      <a class="btn btn--primary" href="https://dash.cloudflare.com/?to=/:account/analytics/web-analytics" target="_blank" rel="noopener noreferrer">Open Cloudflare Analytics ↗</a>
    </section>

    <section class="analytics-grid section-block" aria-label="Editorial metrics">
      <article class="card"><strong>{myths.length}</strong><span>published explainers</span></article>
      <article class="card"><strong>{claims}</strong><span>registered claims</span></article>
      <article class="card"><strong>{sources}</strong><span>source records</span></article>
      <article class="card"><strong>{reviewed}/{myths.length}</strong><span>independently reviewed</span></article>
    </section>

    <section class="dashboard-grid section-block">
      <article class="card dashboard-panel"><p class="eyebrow">Verdict mix</p><h2>How the library classifies claims</h2><ul class="health-list">{Object.entries(verdicts).map(([verdict, count]) => <li><span>{label(verdict)}</span><strong>{count}</strong></li>)}</ul></article>
      <article class="card dashboard-panel"><p class="eyebrow">Trust gap</p><h2>What still needs human work</h2><ul class="health-list"><li><span>External reviews</span><strong>{reviewed === myths.length ? "Complete" : `${myths.length - reviewed} pending`}</strong></li><li><span>Sources with archive links</span><strong>{myths.reduce((total, myth) => total + myth.data.sources.filter((source) => Boolean(source.archivedUrl)).length, 0)}</strong></li><li><span>Selection rationales</span><strong>{myths.length}/{myths.length}</strong></li></ul><a class="btn" href="/methodology#selection">Read selection policy →</a></article>
    </section>

    <p class="fine-print">This page is an editorial dashboard, not a public popularity ranking. Visitor analytics are intentionally not duplicated here until a verified analytics data connection is configured.</p>
  </main>
</BaseLayout>
