---
import BaseLayout from "../layouts/BaseLayout.astro";
import MythCard from "../components/MythCard.astro";
import InstallApp from "../components/InstallApp.astro";
import { getVisibleMyths } from "../lib/content";
const myths = (await getVisibleMyths()).sort((a,b)=>b.data.publishedAt.valueOf()-a.data.publishedAt.valueOf());
const featured = myths.find((entry)=>entry.data.featured) ?? myths[0];
const recent = myths.filter((entry)=>entry.id!==featured?.id).slice(0,4);
const reviewedCount = myths.filter((entry)=>entry.data.publicationStatus==="reviewed").length;
const sourceCount = myths.reduce((sum,entry)=>sum+entry.data.sources.length,0);
---
<BaseLayout title="Qazaq Lens" description="Concise, sourced and correctable cultural context about Kazakhstan for international readers.">
  <section class="home-hero">
    <div class="wrap-wide home-hero-grid">
      <div class="home-hero-copy">
        <p class="eyebrow">Independent evidence library</p>
        <h1>See Kazakhstan beyond the shortcut.</h1>
        <p class="lead">Fast explanations for the moments when a meme, film or assumption becomes someone’s entire picture of a real country.</p>
        <div class="button-row">
          <a class="btn btn--primary" href="/start">Understand Kazakhstan in 60 seconds</a>
          <a class="btn" href="/myths">Browse checked claims</a>
        </div>
        <dl class="hero-stats">
          <div><dt>{myths.length}</dt><dd>public explainers</dd></div>
          <div><dt>{sourceCount}</dt><dd>visible sources</dd></div>
          <div><dt>{reviewedCount}</dt><dd>independently reviewed</dd></div>
        </dl>
      </div>
      <div class="lens-visual" aria-hidden="true">
        <div class="lens-orbit lens-orbit--one"></div><div class="lens-orbit lens-orbit--two"></div>
        <div class="lens-center"><span>Context</span><strong>before certainty</strong></div>
        <span class="visual-label visual-label--one">History</span><span class="visual-label visual-label--two">Language</span><span class="visual-label visual-label--three">Culture</span><span class="visual-label visual-label--four">Evidence</span>
      </div>
    </div>
  </section>

  <section class="trust-strip"><div class="wrap-wide trust-grid"><span>Claims linked to evidence</span><span>Uncertainty shown openly</span><span>Corrections accepted publicly</span><span>No ads or tracking profiles</span></div></section>

  {featured && <section class="wrap-wide section-block"><div class="section-heading-row"><div><p class="eyebrow">Flagship explainer</p><h2>Start with the most common reference</h2></div><a href="/myths">View all →</a></div><MythCard href={`/myths/${featured.data.slug}`} title={featured.data.title} mythStatement={featured.data.mythStatement} summary={featured.data.summary} verdict={featured.data.verdict} publicationStatus={featured.data.publicationStatus} lastReviewedAt={featured.data.lastReviewedAt} topics={featured.data.topics} /></section>}

  <section class="wrap-wide section-block principles-grid">
    <div class="principle-card"><span class="principle-number">01</span><p class="eyebrow">Traceable</p><h2>Every important claim has an evidence path.</h2><p>Claim IDs connect the article text to independent publishers in a public ledger.</p></div>
    <div class="principle-card"><span class="principle-number">02</span><p class="eyebrow">Honest</p><h2>Facts and interpretations are not blended.</h2><p>Confidence, disagreements and review status stay visible instead of being hidden behind polished language.</p></div>
    <div class="principle-card"><span class="principle-number">03</span><p class="eyebrow">Correctable</p><h2>Readers can challenge the work.</h2><p>Anyone can submit a stronger source, missing context or a wording problem without creating an account.</p></div>
  </section>

  {recent.length>0 && <section class="wrap-wide section-block"><div class="section-heading-row"><div><p class="eyebrow">Evidence library</p><h2>More claims worth checking</h2></div><a href="/myths">Explore all →</a></div><div class="myth-grid">{recent.map((entry)=><MythCard compact href={`/myths/${entry.data.slug}`} title={entry.data.title} mythStatement={entry.data.mythStatement} summary={entry.data.summary} verdict={entry.data.verdict} publicationStatus={entry.data.publicationStatus} lastReviewedAt={entry.data.lastReviewedAt} topics={entry.data.topics} />)}</div></section>}

  <section class="wrap-wide section-block"><InstallApp /></section>

  <section class="wrap closing-note"><p>Qazaq Lens does not claim that Kazakhstan is problem-free, and it does not speak for every Kazakhstani. Its job is narrower: separate checkable context from fiction, shorthand and overconfident generalization.</p></section>
</BaseLayout>
