---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Correction moderation" description="Private correction moderation workspace for Qazaq Lens." noindex={true}>
  <section class="wrap page-hero moderation-page">
    <p class="eyebrow">Private workspace</p><h1>Correction moderation.</h1>
    <p class="lead">Review source reports before changing a published article. The admin token stays in this browser session and is never rendered into the page.</p>
    <form class="moderation-login" data-correction-login><label>Admin token<input type="password" name="token" autocomplete="off" required /></label><button class="btn btn--primary" type="submit">Load reports</button><p class="form-status" data-correction-status role="status" aria-live="polite"></p></form>
    <section class="moderation-list" data-correction-list hidden aria-live="polite"></section>
  </section>
</BaseLayout>
<script>
  const login = document.querySelector<HTMLFormElement>("[data-correction-login]"); const list = document.querySelector<HTMLElement>("[data-correction-list]"); const status = document.querySelector<HTMLElement>("[data-correction-status]"); let token = "";
  const escape = (value: string) => value.replace(/[<>&]/g, (char) => ({ "<": "&lt;", ">": "&gt;", "&": "&amp;" }[char] ?? char));
  const load = async () => { if (!list) return; const response = await fetch("/api/corrections/moderate", { headers: { authorization: `Bearer ${token}` } }); const data = await response.json(); if (!response.ok) throw new Error(data.message ?? "Could not load reports."); const reports = data.reports ?? []; list.hidden = false; list.innerHTML = reports.length ? reports.map((report: {id:string;page_url:string;page_title?:string;issue:string;reason:string;source_url:string;source_title?:string;suggestion?:string;reporter_name?:string;reporter_email?:string;status:string;created_at:string}) => `<article class="moderation-card" data-report-id="${escape(report.id)}"><div class="moderation-card-meta"><strong>${escape(report.page_title ?? report.page_url)}</strong><span>${escape(report.status)}</span><time>${new Date(report.created_at + "Z").toLocaleString()}</time></div><p><strong>Issue:</strong> ${escape(report.issue)}</p><p><strong>Reason:</strong> ${escape(report.reason)}</p><p><strong>Suggested source:</strong> <a data-source-url="${escape(report.source_url)}" target="_blank" rel="noopener">${escape(report.source_title ?? report.source_url)}</a></p>${report.suggestion ? `<p><strong>Suggested wording:</strong> ${escape(report.suggestion)}</p>` : ""}<small>${escape(report.reporter_name ?? "Anonymous")} · ${escape(report.reporter_email ?? "No email")}</small><div class="button-row"><button class="btn" data-correction-status="reviewing" type="button">Mark reviewing</button><button class="btn btn--primary" data-correction-status="accepted" type="button">Accept</button><button class="btn" data-correction-status="rejected" type="button">Reject</button><button class="btn" data-correction-status="resolved" type="button">Resolve</button></div></article>`).join("") : `<p class="comments-empty">No open correction reports.</p>`; list.querySelectorAll<HTMLElement>("[data-source-url]").forEach((link) => link.setAttribute("href", link.dataset.sourceUrl ?? "#")); list.querySelectorAll<HTMLButtonElement>("[data-correction-status]").forEach((button) => button.addEventListener("click", async () => { const card = button.closest<HTMLElement>("[data-report-id]"); const id = card?.dataset.reportId; if (!id) return; button.disabled = true; const update = await fetch("/api/corrections/moderate", { method: "PATCH", headers: { authorization: `Bearer ${token}`, "content-type": "application/json" }, body: JSON.stringify({ id, status: button.dataset.correctionStatus }) }); if (update.ok && button.dataset.correctionStatus !== "reviewing") card?.remove(); else button.disabled = false; })); };
  login?.addEventListener("submit", async (event) => { event.preventDefault(); if (!login.reportValidity()) return; token = String(new FormData(login).get("token") ?? ""); if (status) status.textContent = "Loading…"; try { await load(); if (status) status.textContent = ""; } catch (error) { if (status) status.textContent = error instanceof Error ? error.message : "Could not load reports."; } });
</script>
