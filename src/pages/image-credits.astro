---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Image credits" description="Licensing and attribution for graphics and photographs used by Qazaq Lens.">
  <article class="wrap article-shell">
    <p class="eyebrow">Image policy</p><h1>Image credits</h1>
    <div class="article-body">
      <p>The current prototype uses only original typographic graphics generated for Qazaq Lens. It does not use film stills, posters or third-party photographs.</p>
      <p>Any future external image must list the creator, original source, license and required attribution on this page before publication.</p>
    </div>
  </article>
</BaseLayout>
