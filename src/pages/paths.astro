---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getVisibleMyths } from "../lib/content";
const myths = await getVisibleMyths();
const paths = [
  { title:"Kazakhstan in 5 minutes", intro:"A compact route through statehood, language, geography and everyday life.", slugs:["part-of-russia","kazakh-and-russian","only-steppe","yurts","capital-astana"] },
  { title:"History and memory", intro:"Follow sovereignty, the Silk Roads, Baikonur and the nuclear legacy.", slugs:["part-of-russia","silk-roads","baikonur","nuclear-weapons","aral-sea-gone"] },
  { title:"Culture without shortcuts", intro:"Separate food, religion, ethnicity, language and media from one-dimensional stereotypes.", slugs:["kazakh-and-russian","ethnic-diversity","secular-muslim","horse-meat-kumys","borat"] },
  { title:"Media literacy route", intro:"Study how viral images, comedy, memes and online restrictions shape a country’s image.", slugs:["borat","kazakhstan-memes","giant-door","internet-closed"] },
];
---
<BaseLayout title="Reading paths" description="Guided reading paths through Qazaq Lens explainers about Kazakhstan.">
  <main class="wrap-wide page-hero"><p class="eyebrow">Guided reading</p><h1>Choose a route, not a rabbit hole.</h1><p class="lead">Each path moves from a memorable shortcut to the evidence needed to complicate it.</p></main>
  <section class="wrap-wide path-grid">{paths.map((path,index)=><article class="path-card card"><span class="path-number">{String(index+1).padStart(2,"0")}</span><p class="eyebrow">{path.slugs.length} stops</p><h2>{path.title}</h2><p>{path.intro}</p><ol>{path.slugs.map((slug)=>{const myth=myths.find((m)=>m.data.slug===slug); return myth && <li><a href={`/myths/${slug}`}>{myth.data.title}</a></li>})}</ol></article>)}</section>
</BaseLayout>
