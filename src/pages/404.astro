---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Page not found" description="The requested Qazaq Lens page could not be found." noindex={true}>
  <section class="wrap page-hero">
    <p class="eyebrow">404</p>
    <h1>Page not found.</h1>
    <p class="lead">The link may be outdated or the article may still be under review.</p>
    <div class="button-row">
      <a class="btn btn--primary" href="/">Return home</a>
      <a class="btn" href="/myths">Browse evidence library</a>
      <a class="btn" href="/start">Kazakhstan in 60 seconds</a>
    </div>
  </section>
</BaseLayout>
