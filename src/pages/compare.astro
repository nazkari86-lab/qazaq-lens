---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getSourceDiversity, getVisibleMyths } from "../lib/content";
const myths = (await getVisibleMyths()).sort((a,b)=>a.data.title.localeCompare(b.data.title));
const compareData = myths.map((myth) => ({ slug: myth.data.slug, title: myth.data.title, verdict: myth.data.verdict, summary: myth.data.summary, topics: myth.data.topics, sources: myth.data.sources.length, reviewed: myth.data.lastReviewedAt.toISOString().slice(0,10) }));
const rankings = {
  recent: [...myths].sort((a,b)=>b.data.lastReviewedAt.valueOf()-a.data.lastReviewedAt.valueOf() || b.data.sources.length-a.data.sources.length),
  sourced: [...myths].sort((a,b)=>b.data.sources.length-a.data.sources.length || b.data.lastReviewedAt.valueOf()-a.data.lastReviewedAt.valueOf()),
  diverse: [...myths].sort((a,b)=>getSourceDiversity(b).score-getSourceDiversity(a).score || b.data.sources.length-a.data.sources.length),
};
const dateLabel = (date: Date) => date.toLocaleDateString("en-GB", { year:"numeric", month:"short", day:"numeric" });
const rankingsData = { recent: rankings.recent.map((m)=>({slug:m.data.slug,title:m.data.title,metric:`Checked ${dateLabel(m.data.lastReviewedAt)} · ${m.data.sources.length} sources`})), sourced: rankings.sourced.map((m)=>({slug:m.data.slug,title:m.data.title,metric:`${m.data.sources.length} sources · ${getSourceDiversity(m).publishers} publishers`})), diverse: rankings.diverse.map((m)=>({slug:m.data.slug,title:m.data.title,metric:`Diversity score ${getSourceDiversity(m).score}/100`})) };
---
<BaseLayout title="Compare explainers" description="Compare verdicts, evidence coverage and topics across Qazaq Lens explainers.">
  <main class="wrap-wide page-hero"><p class="eyebrow">Evidence comparison</p><h1>Put the shortcuts side by side.</h1><p class="lead">Select up to four explainers to compare their verdicts, source coverage and review dates.</p></main>
  <section class="wrap-wide section-block compare-rankings"><div class="section-heading-row"><div><p class="eyebrow">Quick orientation</p><h2>Find the strongest starting point</h2></div><span class="section-count">Updated from article metadata</span></div><div class="ranking-tabs"><button class="filter-chip is-active" type="button" data-ranking-tab="recent">Most recently checked</button><button class="filter-chip" type="button" data-ranking-tab="sourced">Most sources</button><button class="filter-chip" type="button" data-ranking-tab="diverse">Most diverse evidence</button></div><div class="ranking-table" data-ranking-panel>{rankings.recent.map((myth, index)=><a class="ranking-row" href={`/myths/${myth.data.slug}`}><strong>{String(index+1).padStart(2,"0")}</strong><span>{myth.data.title}</span><small>Checked {dateLabel(myth.data.lastReviewedAt)} · {myth.data.sources.length} sources</small></a>)}</div></section>
  <section class="wrap-wide compare-tool"><div class="compare-picker" aria-label="Choose explainers">{myths.map((myth)=><label class="compare-option"><input type="checkbox" value={myth.data.slug} data-compare-option /><span>{myth.data.title}</span><small>{myth.data.verdict} · {myth.data.sources.length} sources</small></label>)}</div><div class="compare-controls"><button class="btn btn--primary" type="button" data-compare-submit disabled>Compare selected</button><span class="form-status" data-compare-status>Select at least two explainers.</span></div><div class="compare-grid" data-compare-grid hidden></div></section>
  <script is:inline define:vars={{ compareData, rankingsData }}>
    const rankingPanel = document.querySelector("[data-ranking-panel]"); document.querySelectorAll("[data-ranking-tab]").forEach((tab) => tab.addEventListener("click", () => { document.querySelectorAll("[data-ranking-tab]").forEach((item) => item.classList.remove("is-active")); tab.classList.add("is-active"); const rows = rankingData[tab.dataset.rankingTab] || []; if (rankingPanel) { rankingPanel.innerHTML = rows.map((row, index) => `<a class="ranking-row" data-ranking-link data-slug="${row.slug}"><strong>${String(index + 1).padStart(2, "0")}</strong><span>${row.title}</span><small>${row.metric}</small></a>`).join(""); rankingPanel.querySelectorAll("[data-ranking-link]").forEach((link) => link.setAttribute("href", "/myths/" + link.dataset.slug)); } }));
    const options = [...document.querySelectorAll("[data-compare-option]")]; const grid = document.querySelector("[data-compare-grid]"); const status = document.querySelector("[data-compare-status]"); const submit = document.querySelector("[data-compare-submit]");
    const selectedItems = () => options.filter((o) => o.checked).map((o) => compareData.find((m) => m.slug === o.value)).filter(Boolean);
    const updateSelection = () => { const selected = selectedItems(); options.forEach((o) => { o.disabled = !o.checked && selected.length >= 4; }); if (status) status.textContent = selected.length < 2 ? "Select at least two explainers." : `${selected.length} selected — ready to compare.`; if (submit) submit.disabled = selected.length < 2; };
    submit?.addEventListener("click", () => { const selected = selectedItems(); if (selected.length < 2 || !grid) return; grid.hidden = false; grid.innerHTML = selected.map((m) => `<article class="compare-card"><p class="eyebrow">${m.verdict.replaceAll("-", " ")}</p><h2><a data-compare-link data-slug="${m.slug}">${m.title}</a></h2><p>${m.summary}</p><div class="compare-meta"><span>${m.sources} sources</span><span>Checked ${m.reviewed}</span></div><div class="topic-row">${m.topics.map((t) => `<span class="topic-chip">${t}</span>`).join("")}</div></article>`).join(""); grid.querySelectorAll("[data-compare-link]").forEach((link) => link.setAttribute("href", "/myths/" + link.dataset.slug)); grid.scrollIntoView({ behavior: "smooth", block: "start" }); });
    options.forEach((o) => o.addEventListener("change", updateSelection)); updateSelection();
  </script>
</BaseLayout>
