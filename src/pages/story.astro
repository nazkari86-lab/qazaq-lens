---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getVisibleMyths } from "../lib/content";

const myths = await getVisibleMyths();
const order = [
  "part-of-russia","kazakh-and-russian","nuclear-weapons","nuclear-energy-weapons","economy-oil",
  "baikonur","ethnic-diversity","secular-muslim","borat","capital-astana","yurts",
  "only-steppe","aral-sea-gone","landlocked-isolated","silk-roads","internet-closed",
  "giant-door","horse-meat-kumys","kazakhstan-memes",
];
const storyMyths = order
  .map(slug => myths.find(e => e.data.slug === slug))
  .filter((e): e is NonNullable<typeof e> => Boolean(e));

const mythMeta: Record<string, { stat: string; statLabel: string; lead: string; arc: string }> = {
  "borat": {
    stat: "2006",
    statLabel: "A comedy film has shaped global perception more than two decades of real reporting",
    lead: "Sacha Baron Cohen filmed in Romania and Moldova. The Kazakhstan in the film is invention. The country it depicts does not exist — and never did.",
    arc: "The image",
  },
  "capital-astana": {
    stat: "1997",
    statLabel: "The government moved its capital north — nearly three decades ago",
    lead: "Almaty lost capital status when institutions relocated 1,000 km north. Astana has been the seat of government longer than many readers have followed the news.",
    arc: "The snapshot",
  },
  "economy-oil": {
    stat: "#1",
    statLabel: "Global uranium producer — oil is one sector in a diversifying economy",
    lead: "Kazakhstan produces more uranium than any other country. It is also a major grain exporter. Sectors in manufacturing, logistics, and fintech are growing rapidly.",
    arc: "The shortcut",
  },
  "ethnic-diversity": {
    stat: "130+",
    statLabel: "Nationalities recorded by the national census",
    lead: "Kazakhs form roughly 70 percent. Russians, Uzbeks, Ukrainians, Uyghurs, Germans, Tatars, Koreans and dozens more make up the rest. Diversity is constitutional policy.",
    arc: "The people",
  },
  "kazakh-and-russian": {
    stat: "Turkic",
    statLabel: "The language family of Kazakh — distinct from Russian's Indo-European family",
    lead: "Kazakh and Russian belong to different language families: Kazakh is Turkic, while Russian is Indo-European. Kazakhstan's multilingual reality and shared script history do not make the languages the same.",
    arc: "The assumption",
  },
  "nuclear-weapons": {
    stat: "1,400",
    statLabel: "Warheads inherited from the USSR — and voluntarily surrendered",
    lead: "The Soviets detonated 456 nuclear devices on Kazakh soil. After independence, Kazakhstan transferred or dismantled all warheads. It is now among the world's strongest non-proliferation advocates.",
    arc: "The aftermath",
  },
  "only-steppe": {
    stat: "9th",
    statLabel: "Largest country on Earth — no single landscape can describe it",
    lead: "The Tian Shan range rises directly behind Almaty. Khan Tengri reaches nearly 7,000 metres. Lake Balkhash spans 600 km. Altai forests cover the east. Steppe is one chapter.",
    arc: "The landscape",
  },
  "part-of-russia": {
    stat: "1991",
    statLabel: "Year of independence — the same month the Soviet Union dissolved",
    lead: "Kazakhstan was a Soviet republic, not a Russian territory. Both were distinct units in the same federation. When that federation dissolved, fifteen sovereign states emerged. Kazakhstan was among them.",
    arc: "The history",
  },
  "yurts": {
    stat: "64%",
    statLabel: "Approximately two-thirds of Kazakhstan's population lived in urban areas on 1 June 2026",
    lead: "The yurt is UNESCO-recognised cultural heritage. It is not standard housing. Almaty has a skyline of high-rise towers. Astana was built largely in the 2000s. Most residents live in apartments.",
    arc: "The symbol",
  },
  "baikonur": {
    stat: "2050",
    statLabel: "Year the current lease agreement is scheduled to end",
    lead: "Baikonur is in Kazakhstan. Russia operates the complex under a lease, which explains the association without changing the geography.",
    arc: "The boundary",
  },
  "silk-roads": {
    stat: "3",
    statLabel: "Countries represented in UNESCO's Chang'an–Tianshan corridor",
    lead: "The Silk Roads were a network, not a single line. Kazakhstan's valleys and settlements were part of the exchange system connecting Central and East Asia.",
    arc: "The route",
  },
  "nuclear-energy-weapons": { stat: "2024", statLabel: "Year Kazakhstan held a referendum on its first nuclear power plant", lead: "Civilian nuclear power is an energy policy question. It is not the same as rebuilding the nuclear arsenal inherited from the Soviet Union.", arc: "The equation" },
  "secular-muslim": { stat: "Secular", statLabel: "Constitutional status of the state — distinct from lived religious identity", lead: "Kazakhstan is Muslim-majority and constitutionally secular. Religious life, freedom of belief and state law belong in the same frame.", arc: "The balance" },
  "aral-sea-gone": { stat: "2005", statLabel: "Year the Kok-Aral Dam helped restore part of the Northern Aral Sea", lead: "The Aral crisis is real and severe, but the story is not simply ‘gone’ or ‘saved’: the north has partially recovered while the wider basin remains damaged.", arc: "The recovery" },
  "landlocked-isolated": { stat: "1st", statLabel: "World's largest landlocked country — connected through the Caspian and overland corridors", lead: "Landlocked creates logistics challenges. It does not make Kazakhstan isolated from trade, ports or the wider world.", arc: "The crossroads" },
  "internet-closed": { stat: "Connected", statLabel: "An active online public sphere that is also restricted by blocking and pressure", lead: "Kazakhstan has online journalism, civic projects and debate. It also has documented limits on access and expression.", arc: "The signal" },
  "giant-door": { stat: "2025", statLabel: "Year a supposed giant doorway in Kazakhstan became a viral internet claim", lead: "A dramatic video can be a powerful meme without being archaeological evidence. The claim remains unverified.", arc: "The hoax" },
  "horse-meat-kumys": { stat: "Heritage", statLabel: "Horse meat and kumys are traditions, not a complete description of every daily diet", lead: "Kazakh cuisine includes horse meat and fermented mare's milk — alongside many other foods and regional habits.", arc: "The table" },
  "kazakhstan-memes": { stat: "236", statLabel: "Kazakhstan-related memes examined in recent digital folklore research", lead: "Memes mix Kazakh, Russian and global formats. They show online communities at a moment, not one personality for an entire country.", arc: "The remix" },
};

const storyData = storyMyths.map(entry => ({
  slug: entry.data.slug,
  title: entry.data.title,
  statement: entry.data.mythStatement,
  verdict: entry.data.verdict,
  heroImage: entry.data.heroImage ?? "",
  heroAlt: entry.data.heroImageAlt ?? "",
  sourceCount: entry.data.sources.length,
  reviewedAt: entry.data.lastReviewedAt.toLocaleDateString("en-GB", { year: "numeric", month: "short" }),
  ...mythMeta[entry.data.slug],
}));
---

<BaseLayout
  title="One country. Nineteen shortcuts. · Qazaq Lens"
  description="Nineteen statements about Kazakhstan have spread far enough to feel like facts. Scroll through each one."
>
  <div class="sw">

    <!-- TITLE SCREEN -->
    <section class="sw-title">
      <div class="sw-title-inner">
        <p class="sw-eyebrow">Qazaq Lens · Visual story</p>
        <h1 class="sw-headline">One country.<br>Nineteen shortcuts.</h1>
        <p class="sw-sub">Nineteen statements about Kazakhstan have spread far enough to feel like facts. Scroll through each one. The evidence follows each claim.</p>
        <div class="sw-scroll-hint" aria-hidden="true">
          <svg width="20" height="28" viewBox="0 0 20 28" fill="none">
            <rect x="1" y="1" width="18" height="22" rx="9" stroke="currentColor" stroke-width="1.5"/>
            <line x1="10" y1="7" x2="10" y2="13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <span>Scroll</span>
        </div>
        <button class="sw-resume" type="button" data-resume hidden>Continue from check <span data-resume-number></span> →</button>
      </div>
      <div class="sw-title-grid" aria-hidden="true">
        {storyData.map((m) => (
          <span class="sw-title-tag">{m.statement}</span>
        ))}
      </div>
    </section>

    <!-- SCROLL SHELL -->
    <section class="sw-shell" aria-label="Nineteen myth evidence checks">
      <div class="sw-progress" aria-hidden="true">
        <span class="sw-progress-fill" data-story-progress></span>
        <span class="sw-progress-label" data-story-progress-label>01 / {storyData.length} · {storyData.length - 1} left</span>
      </div>
      <nav class="sw-chapters" aria-label="Story chapters">
        <span class="sw-chapters-title">Chapters</span>
        {storyData.map((myth, i) => <a href={`#story-${myth.slug}`} data-chapter-link={i} aria-label={`Go to ${myth.title}`}><span>{String(i + 1).padStart(2, "0")}</span><b>{myth.arc}</b></a>)}
      </nav>

      <!-- TEXT COLUMN -->
      <div class="sw-steps" id="sw-steps">
        {storyData.map((myth, i) => (
          <article class="sw-step" id={`story-${myth.slug}`} data-step={i} data-slug={myth.slug} aria-labelledby={`story-step-${i}`}>
            <div class="sw-step-meta">
              <span class="sw-counter">{String(i + 1).padStart(2, "0")} / {storyData.length}</span>
              <span class="sw-tag">{myth.arc} · common claim</span>
            </div>
            <blockquote class="sw-myth" id={`story-step-${i}`}>
              <span class="sw-myth-mark">"</span>{myth.statement}<span class="sw-myth-mark">"</span>
            </blockquote>
            <hr class="sw-rule" />
            <p class="sw-lead">{myth.lead}</p>
            <div class="sw-stat">
              <strong class="sw-stat-value">{myth.stat}</strong>
              <span class="sw-stat-label">{myth.statLabel}</span>
            </div>
            <div class:list={["sw-verdict", `sw-verdict--${myth.verdict}`]}>
              {myth.verdict === "false" ? "FALSE" : "MISLEADING"}
            </div>
            <a class="sw-link" href={`/myths/${myth.slug}`}>Read the full evidence check <span aria-hidden="true">→</span></a>
            {storyData[i + 1] && <a class="sw-next" href={`#story-${storyData[i + 1].slug}`}><span>Next chapter</span><strong>{storyData[i + 1].arc}</strong><i aria-hidden="true">↓</i></a>}
          </article>
        ))}

        <!-- PATTERN STEP -->
        <article class="sw-step sw-step--pattern" data-step="pattern">
          <div class="sw-step-meta">
            <span class="sw-counter">— / {storyData.length}</span>
            <span class="sw-tag">The pattern</span>
          </div>
          <h2 class="sw-pattern-head">Nineteen myths.<br>Four origins.</h2>
          <p class="sw-lead">These shortcuts are not random. Almost every one traces to the same three sources — and understanding that is the beginning of seeing the actual country.</p>
          <div class="sw-pattern-grid">
            <div class="sw-pattern-card">
              <span class="sw-pattern-n">01</span>
              <h3>Soviet-era confusion</h3>
              <p>Russia ≠ Soviet Union. Kazakhstan was a separate Soviet republic for seven decades. When people say "Soviet," they often mean "Russian." They are not the same.</p>
            </div>
            <div class="sw-pattern-card">
              <span class="sw-pattern-n">02</span>
              <h3>A single film</h3>
              <p>One 2006 comedy has shaped international perception more than decades of journalism. The character of Borat was a satire of Western prejudice — not a portrait of Kazakhstan.</p>
            </div>
            <div class="sw-pattern-card">
              <span class="sw-pattern-n">03</span>
              <h3>Outdated snapshots</h3>
              <p>Almaty as capital, oil as the dominant export, yurts as housing — all were accurate at some point. The country moved on. The reference did not.</p>
            </div>
          </div>
        </article>
      </div>

      <!-- STICKY VISUAL PANEL -->
      <div class="sw-visual-wrap">
        <div class="sw-visual" data-visual>

          <!-- One visible photo stage: the current topic owns the frame. -->
          <div class="sw-photo is-active" data-photo-stage>
            <img data-story-image src={storyData[0].heroImage} alt="" loading="eager" decoding="async" />
          </div>

          <!-- Per-myth color tint -->
          <div class="sw-photo-tint" data-photo-tint></div>

          <!-- Gradient overlays -->
          <div class="sw-photo-overlay sw-photo-overlay--top"></div>
          <div class="sw-photo-overlay sw-photo-overlay--bottom"></div>

          <!-- Myth statement on photo -->
          <div class="sw-photo-myth" data-photo-myth aria-hidden="true">
            <span class="sw-photo-myth-text" data-photo-myth-text>
              "{storyData[0].statement}"
            </span>
          </div>

          <!-- HUD top -->
          <div class="sw-hud sw-hud--top">
            <span class="sw-hud-counter" data-hud-counter>01 / {storyData.length}</span>
            <span class="sw-hud-label" data-hud-label>{storyData[0].title.split(":")[0]}</span>
          </div>

          <!-- HUD bottom -->
          <div class="sw-hud sw-hud--bottom">
            <span class="sw-hud-verdict" data-hud-verdict data-verdict={storyData[0].verdict}>
              {storyData[0].verdict === "false" ? "FALSE" : "MISLEADING"}
            </span>
            <span class="sw-hud-sources" data-hud-sources>{storyData[0].sourceCount} sources · {storyData[0].reviewedAt}</span>
            <span class="sw-hud-scroll" data-hud-scroll>Scroll to continue</span>
          </div>
        </div>
      </div>
    </section>

    <!-- MEMORY CHECK: a short active-recall payoff after the visual story. -->
    <section class="sw-quiz" aria-labelledby="sw-quiz-title">
      <div class="sw-quiz-inner">
        <p class="sw-eyebrow">Before you leave</p>
        <h2 id="sw-quiz-title">Keep the context, not the shortcut.</h2>
        <p class="sw-quiz-intro">Three quick questions. Your answer is never stored or sent anywhere.</p>
        <div class="sw-quiz-question" data-quiz-question="0">
          <span class="sw-quiz-count">01 / 03</span><h3>Which statement best describes Baikonur?</h3>
          <div class="sw-quiz-options"><button type="button" data-answer="wrong">It is in Russia.</button><button type="button" data-answer="correct">It is in Kazakhstan and operated by Russia under lease.</button><button type="button" data-answer="wrong">It is an independent country.</button></div>
        </div>
        <div class="sw-quiz-question" data-quiz-question="1" hidden>
          <span class="sw-quiz-count">02 / 03</span><h3>What is the problem with “Kazakhstan is only steppe”?</h3>
          <div class="sw-quiz-options"><button type="button" data-answer="correct">It turns one landscape into a whole-country description.</button><button type="button" data-answer="wrong">There is no steppe in Kazakhstan.</button><button type="button" data-answer="wrong">The country has no mountains.</button></div>
        </div>
        <div class="sw-quiz-question" data-quiz-question="2" hidden>
          <span class="sw-quiz-count">03 / 03</span><h3>What does Qazaq Lens separate?</h3>
          <div class="sw-quiz-options"><button type="button" data-answer="wrong">Kazakhstan from every neighbouring country.</button><button type="button" data-answer="correct">Checkable context from fiction and overconfident generalisation.</button><button type="button" data-answer="wrong">Facts from all interpretation.</button></div>
        </div>
        <p class="sw-quiz-feedback" data-quiz-feedback role="status" aria-live="polite"></p>
        <div class="sw-quiz-result" data-quiz-result hidden><strong data-quiz-score></strong><span>You now have the useful version of the story.</span><a href="/myths">Keep exploring the evidence →</a></div>
      </div>
    </section>

    <!-- ENDING -->
    <section class="sw-ending">
      <div class="sw-ending-inner">
        <p class="sw-eyebrow">The point is not a new stereotype</p>
        <h2 class="sw-ending-head">Context makes the picture larger.</h2>
        <p class="sw-ending-body">
          These eleven checks are a starting point, not a summary of a country. Follow the evidence, keep the uncertainty visible, and let Kazakhstan stay bigger than the shortcut assigned to it.
        </p>
        <a class="sw-cta" href="/myths">Open the full evidence library</a>
        <a class="sw-secondary-cta" href="/sources">See the source map first →</a>
        <p class="sw-credits">
          Sources: United Nations, CIA World Factbook, UNESCO, World Bank, Bureau of National Statistics of Kazakhstan, Nuclear Threat Initiative, Encyclopedia Britannica.
        </p>
      </div>
    </section>

  </div>

  <script is:inline type="application/json" id="sw-data" set:html={JSON.stringify(storyData)}></script>
</BaseLayout>

<style>
/* ─── REGISTERED COLOR PROPERTIES (enables smooth transitions) ─── */
@property --sw-accent {
  syntax: '<color>';
  inherits: true;
  initial-value: #c5973e;
}
@property --sw-tint {
  syntax: '<color>';
  inherits: true;
  initial-value: transparent;
}

/* ─── RESET & TOKENS ─────────────────────────────────────── */
.sw {
  --sw-bg:    #080807;
  --sw-ink:   #f0ede5;
  --sw-muted: #7e7a73;
  --sw-line:  rgba(240,237,229,.12);
  --sw-gold:  #c5973e;
  --sw-red:   #d94f35;
  --sw-amber: #d4823a;
  --sw-accent: #c5973e;
  --sw-tint:   transparent;
  --sw-font-display: Georgia, 'Times New Roman', serif;
  --sw-font-ui:      ui-monospace, 'Menlo', monospace;
  background: var(--sw-bg);
  color: var(--sw-ink);
  margin: 0 calc(-1 * var(--page-pad, 0px));
  transition: --sw-accent .65s ease, --sw-tint .65s ease;
}

/* ─── TITLE SCREEN ───────────────────────────────────────── */
.sw-title {
  position: relative;
  min-height: 100svh;
  display: flex;
  align-items: center;
  overflow: hidden;
  padding: clamp(4rem,10vw,8rem) clamp(1.5rem,6vw,6rem);
}
.sw-title-inner {
  position: relative;
  z-index: 2;
  max-width: 780px;
}
.sw-eyebrow {
  font-family: var(--sw-font-ui);
  font-size: .68rem;
  text-transform: uppercase;
  letter-spacing: .12em;
  color: var(--sw-accent);
  margin: 0 0 1.8rem;
}
.sw-headline {
  font-family: var(--sw-font-display);
  font-size: clamp(3.8rem, 11vw, 9.5rem);
  font-weight: 400;
  line-height: .93;
  letter-spacing: -.04em;
  margin: 0 0 2rem;
  color: var(--sw-ink);
}
.sw-sub {
  font-size: clamp(1.1rem, 1.8vw, 1.35rem);
  line-height: 1.55;
  color: var(--sw-muted);
  max-width: 52ch;
  margin: 0 0 3rem;
}
.sw-scroll-hint {
  display: flex;
  align-items: center;
  gap: .6rem;
  color: var(--sw-muted);
  font-family: var(--sw-font-ui);
  font-size: .7rem;
  letter-spacing: .08em;
  text-transform: uppercase;
  animation: sw-bob 2.4s ease-in-out infinite;
}
.sw-resume{display:none;margin-top:1.5rem;border:1px solid color-mix(in srgb,var(--sw-accent) 55%,transparent);background:transparent;color:var(--sw-accent);padding:.7rem 1rem;border-radius:3px;font:700 .65rem var(--sw-font-ui);letter-spacing:.08em;text-transform:uppercase;cursor:pointer}.sw-resume:hover{background:var(--sw-accent);color:var(--sw-bg)}
@keyframes sw-bob {
  0%,100% { transform: translateY(0) }
  50%      { transform: translateY(6px) }
}
/* Background tag cloud */
.sw-title-grid {
  position: absolute;
  inset: 0;
  z-index: 1;
  display: flex;
  flex-wrap: wrap;
  align-content: center;
  gap: .8rem 1.2rem;
  padding: 4rem;
  pointer-events: none;
  opacity: .055;
  filter: blur(1px);
}
.sw-title-tag {
  font-family: var(--sw-font-display);
  font-size: clamp(.9rem, 2vw, 1.6rem);
  font-style: italic;
  white-space: nowrap;
  color: var(--sw-ink);
}

/* ─── SCROLL SHELL ───────────────────────────────────────── */
.sw-shell {
  position: relative;
  display: grid;
  grid-template-columns: minmax(0, 1.45fr) minmax(320px, .85fr);
  min-height: 100vh;
}
.sw-progress {
  position: fixed;
  z-index: 20;
  inset: 0 0 auto;
  height: 3px;
  background: rgba(255,255,255,.12);
  pointer-events: none;
}
.sw-progress-fill {
  display: block;
  width: 0;
  height: 100%;
  background: var(--sw-accent);
  box-shadow: 0 0 14px var(--sw-accent);
  transition: width .35s ease, background .35s ease;
}
.sw-progress-label {
  position: absolute;
  right: clamp(1rem, 3vw, 2.5rem);
  top: .7rem;
  color: rgba(240,237,229,.55);
  font: .58rem var(--sw-font-ui);
  letter-spacing: .1em;
  text-transform: uppercase;
  transition: color .3s ease;
}
.sw-chapters{position:fixed;z-index:18;left:1rem;top:50%;transform:translateY(-50%);display:grid;gap:.35rem;padding:.45rem;border:1px solid var(--sw-line);border-radius:5px;background:#080807b8;backdrop-filter:blur(12px)}.sw-chapters-title{padding:.25rem .35rem;color:var(--sw-muted);font: .55rem var(--sw-font-ui);letter-spacing:.1em;text-transform:uppercase}.sw-chapters a{display:flex;align-items:center;gap:.45rem;width:1.8rem;min-height:1.5rem;overflow:hidden;color:var(--sw-muted);text-decoration:none;transition:width .25s,color .25s}.sw-chapters a span{font: .58rem var(--sw-font-ui);color:var(--sw-accent)}.sw-chapters a b{font: .58rem var(--sw-font-ui);font-weight:400;white-space:nowrap;opacity:0;transition:opacity .2s}.sw-chapters:hover a,.sw-chapters a:focus-visible{width:7.5rem}.sw-chapters:hover a b,.sw-chapters a:focus-visible b{opacity:1}.sw-chapters a.is-active{color:var(--sw-ink)}.sw-chapters a.is-active::before{content:"";position:absolute;left:.45rem;width:2px;height:1rem;background:var(--sw-accent)}
@media (max-width: 860px) {
  .sw-shell { grid-template-columns: 1fr; }
}

/* ─── TEXT STEPS ─────────────────────────────────────────── */
.sw-steps {
  padding: 0 clamp(1.5rem,5vw,4rem);
}
.sw-step {
  min-height: 90vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 6rem 0;
  border-top: 1px solid var(--sw-line);
  opacity: 0;
  transform: translateY(20px);
  transition: opacity .5s ease, transform .5s ease;
}
.sw-step:first-child { border-top: 0; }
.sw-step.is-active {
  opacity: 1;
  transform: none;
}
.sw-step-meta {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 1.4rem;
}
.sw-counter {
  font-family: var(--sw-font-ui);
  font-size: .65rem;
  letter-spacing: .1em;
  color: var(--sw-accent);
  text-transform: uppercase;
}
.sw-tag {
  font-family: var(--sw-font-ui);
  font-size: .65rem;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: var(--sw-muted);
}
.sw-myth {
  font-family: var(--sw-font-display);
  font-style: italic;
  font-size: clamp(1.6rem, 3.5vw, 2.6rem);
  line-height: 1.18;
  letter-spacing: -.025em;
  color: var(--sw-ink);
  margin: 0 0 1.5rem;
  padding: 0;
  border: 0;
}
.sw-myth-mark { color: var(--sw-accent); }
.sw-rule {
  border: 0;
  border-top: 1px solid var(--sw-line);
  margin: 0 0 1.5rem;
}
.sw-lead {
  font-size: clamp(.95rem, 1.5vw, 1.1rem);
  line-height: 1.65;
  color: var(--sw-muted);
  max-width: 50ch;
  margin: 0 0 2rem;
}
.sw-stat {
  display: flex;
  align-items: baseline;
  gap: 1rem;
  flex-wrap: wrap;
  margin: 0 0 1.4rem;
  padding: 1.1rem 0;
  border-top: 1px solid var(--sw-line);
  border-bottom: 1px solid var(--sw-line);
}
.sw-stat-value {
  font-family: var(--sw-font-display);
