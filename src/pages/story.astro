---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getVisibleMyths } from "../lib/content";

const myths = await getVisibleMyths();
const order = [
  "borat","capital-astana","economy-oil","ethnic-diversity",
  "kazakh-and-russian","nuclear-weapons","only-steppe","part-of-russia","yurts",
  "baikonur","silk-roads",
];
const storyMyths = order
  .map(slug => myths.find(e => e.data.slug === slug))
  .filter((e): e is NonNullable<typeof e> => Boolean(e));

const mythMeta: Record<string, { stat: string; statLabel: string; lead: string; arc: string }> = {
  "borat": {
    stat: "2006",
    statLabel: "A comedy film has shaped global perception more than two decades of real reporting",
    lead: "Sacha Baron Cohen filmed in Romania and Moldova. The Kazakhstan in the film is invention. The country it depicts does not exist — and never did.",
    arc: "The image",
  },
  "capital-astana": {
    stat: "1997",
    statLabel: "The government moved its capital north — nearly three decades ago",
    lead: "Almaty lost capital status when institutions relocated 1,000 km north. Astana has been the seat of government longer than many readers have followed the news.",
    arc: "The snapshot",
  },
  "economy-oil": {
    stat: "#1",
    statLabel: "Global uranium producer — oil is one sector in a diversifying economy",
    lead: "Kazakhstan produces more uranium than any other country. It is also a major grain exporter. Sectors in manufacturing, logistics, and fintech are growing rapidly.",
    arc: "The shortcut",
  },
  "ethnic-diversity": {
    stat: "130+",
    statLabel: "Nationalities recorded by the national census",
    lead: "Kazakhs form roughly 70 percent. Russians, Uzbeks, Ukrainians, Uyghurs, Germans, Tatars, Koreans and dozens more make up the rest. Diversity is constitutional policy.",
    arc: "The people",
  },
  "kazakh-and-russian": {
    stat: "Turkic",
    statLabel: "The language family of Kazakh — distinct from Russian's Indo-European family",
    lead: "Kazakh and Russian belong to different language families: Kazakh is Turkic, while Russian is Indo-European. Kazakhstan's multilingual reality and shared script history do not make the languages the same.",
    arc: "The assumption",
  },
  "nuclear-weapons": {
    stat: "1,400",
    statLabel: "Warheads inherited from the USSR — and voluntarily surrendered",
    lead: "The Soviets detonated 456 nuclear devices on Kazakh soil. After independence, Kazakhstan transferred or dismantled all warheads. It is now among the world's strongest non-proliferation advocates.",
    arc: "The aftermath",
  },
  "only-steppe": {
    stat: "9th",
    statLabel: "Largest country on Earth — no single landscape can describe it",
    lead: "The Tian Shan range rises directly behind Almaty. Khan Tengri reaches nearly 7,000 metres. Lake Balkhash spans 600 km. Altai forests cover the east. Steppe is one chapter.",
    arc: "The landscape",
  },
  "part-of-russia": {
    stat: "1991",
    statLabel: "Year of independence — the same month the Soviet Union dissolved",
    lead: "Kazakhstan was a Soviet republic, not a Russian territory. Both were distinct units in the same federation. When that federation dissolved, fifteen sovereign states emerged. Kazakhstan was among them.",
    arc: "The history",
  },
  "yurts": {
    stat: "64%",
    statLabel: "Approximately two-thirds of Kazakhstan's population lived in urban areas on 1 June 2026",
    lead: "The yurt is UNESCO-recognised cultural heritage. It is not standard housing. Almaty has a skyline of high-rise towers. Astana was built largely in the 2000s. Most residents live in apartments.",
    arc: "The symbol",
  },
  "baikonur": {
    stat: "2050",
    statLabel: "Year the current lease agreement is scheduled to end",
    lead: "Baikonur is in Kazakhstan. Russia operates the complex under a lease, which explains the association without changing the geography.",
    arc: "The boundary",
  },
  "silk-roads": {
    stat: "3",
    statLabel: "Countries represented in UNESCO's Chang'an–Tianshan corridor",
    lead: "The Silk Roads were a network, not a single line. Kazakhstan's valleys and settlements were part of the exchange system connecting Central and East Asia.",
    arc: "The route",
  },
};

const storyData = storyMyths.map(entry => ({
  slug: entry.data.slug,
  title: entry.data.title,
  statement: entry.data.mythStatement,
  verdict: entry.data.verdict,
  heroImage: entry.data.heroImage ?? "",
  heroAlt: entry.data.heroImageAlt ?? "",
  sourceCount: entry.data.sources.length,
  reviewedAt: entry.data.lastReviewedAt.toLocaleDateString("en-GB", { year: "numeric", month: "short" }),
  ...mythMeta[entry.data.slug],
}));
---

<BaseLayout
  title="One country. Eleven shortcuts. · Qazaq Lens"
  description="Eleven statements about Kazakhstan have spread far enough to feel like facts. Scroll through each one."
>
  <div class="sw">

    <!-- TITLE SCREEN -->
    <section class="sw-title">
      <div class="sw-title-inner">
        <p class="sw-eyebrow">Qazaq Lens · Visual story</p>
        <h1 class="sw-headline">One country.<br>Eleven shortcuts.</h1>
        <p class="sw-sub">Eleven statements about Kazakhstan have spread far enough to feel like facts. Scroll through each one. The evidence follows each claim.</p>
        <div class="sw-scroll-hint" aria-hidden="true">
          <svg width="20" height="28" viewBox="0 0 20 28" fill="none">
            <rect x="1" y="1" width="18" height="22" rx="9" stroke="currentColor" stroke-width="1.5"/>
            <line x1="10" y1="7" x2="10" y2="13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <span>Scroll</span>
        </div>
      </div>
      <div class="sw-title-grid" aria-hidden="true">
        {storyData.map((m) => (
          <span class="sw-title-tag">{m.statement}</span>
        ))}
      </div>
    </section>

    <!-- SCROLL SHELL -->
    <section class="sw-shell" aria-label="Eleven myth evidence checks">
      <div class="sw-progress" aria-hidden="true">
        <span class="sw-progress-fill" data-story-progress></span>
      </div>

      <!-- TEXT COLUMN -->
      <div class="sw-steps" id="sw-steps">
        {storyData.map((myth, i) => (
          <article class="sw-step" data-step={i} data-slug={myth.slug} aria-labelledby={`story-step-${i}`}>
            <div class="sw-step-meta">
              <span class="sw-counter">{String(i + 1).padStart(2, "0")} / {storyData.length}</span>
              <span class="sw-tag">{myth.arc} · common claim</span>
            </div>
            <blockquote class="sw-myth" id={`story-step-${i}`}>
              <span class="sw-myth-mark">"</span>{myth.statement}<span class="sw-myth-mark">"</span>
            </blockquote>
            <hr class="sw-rule" />
            <p class="sw-lead">{myth.lead}</p>
            <div class="sw-stat">
              <strong class="sw-stat-value">{myth.stat}</strong>
              <span class="sw-stat-label">{myth.statLabel}</span>
            </div>
            <div class:list={["sw-verdict", `sw-verdict--${myth.verdict}`]}>
              {myth.verdict === "false" ? "FALSE" : "MISLEADING"}
            </div>
            <a class="sw-link" href={`/myths/${myth.slug}`}>Read the full evidence check <span aria-hidden="true">→</span></a>
          </article>
        ))}

        <!-- PATTERN STEP -->
        <article class="sw-step sw-step--pattern" data-step="pattern">
          <div class="sw-step-meta">
            <span class="sw-counter">— / {storyData.length}</span>
            <span class="sw-tag">The pattern</span>
          </div>
          <h2 class="sw-pattern-head">Eleven myths.<br>Four origins.</h2>
          <p class="sw-lead">These shortcuts are not random. Almost every one traces to the same three sources — and understanding that is the beginning of seeing the actual country.</p>
          <div class="sw-pattern-grid">
            <div class="sw-pattern-card">
              <span class="sw-pattern-n">01</span>
              <h3>Soviet-era confusion</h3>
              <p>Russia ≠ Soviet Union. Kazakhstan was a separate Soviet republic for seven decades. When people say "Soviet," they often mean "Russian." They are not the same.</p>
            </div>
            <div class="sw-pattern-card">
              <span class="sw-pattern-n">02</span>
              <h3>A single film</h3>
              <p>One 2006 comedy has shaped international perception more than decades of journalism. The character of Borat was a satire of Western prejudice — not a portrait of Kazakhstan.</p>
            </div>
            <div class="sw-pattern-card">
              <span class="sw-pattern-n">03</span>
              <h3>Outdated snapshots</h3>
              <p>Almaty as capital, oil as the dominant export, yurts as housing — all were accurate at some point. The country moved on. The reference did not.</p>
            </div>
          </div>
        </article>
      </div>

      <!-- STICKY VISUAL PANEL -->
      <div class="sw-visual-wrap">
        <div class="sw-visual" data-visual>

          <!-- One visible photo stage: the current topic owns the frame. -->
          <div class="sw-photo is-active" data-photo-stage>
            <img data-story-image src={storyData[0].heroImage} alt="" loading="eager" decoding="async" />
          </div>

          <!-- Per-myth color tint -->
          <div class="sw-photo-tint" data-photo-tint></div>

          <!-- Gradient overlays -->
          <div class="sw-photo-overlay sw-photo-overlay--top"></div>
          <div class="sw-photo-overlay sw-photo-overlay--bottom"></div>

          <!-- Myth statement on photo -->
          <div class="sw-photo-myth" data-photo-myth aria-hidden="true">
            <span class="sw-photo-myth-text" data-photo-myth-text>
              "{storyData[0].statement}"
            </span>
          </div>

          <!-- HUD top -->
          <div class="sw-hud sw-hud--top">
            <span class="sw-hud-counter" data-hud-counter>01 / {storyData.length}</span>
            <span class="sw-hud-label" data-hud-label>{storyData[0].title.split(":")[0]}</span>
          </div>

          <!-- HUD bottom -->
          <div class="sw-hud sw-hud--bottom">
            <span class="sw-hud-verdict" data-hud-verdict data-verdict={storyData[0].verdict}>
              {storyData[0].verdict === "false" ? "FALSE" : "MISLEADING"}
            </span>
            <span class="sw-hud-sources" data-hud-sources>{storyData[0].sourceCount} sources · {storyData[0].reviewedAt}</span>
            <span class="sw-hud-scroll" data-hud-scroll>Scroll to continue</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ENDING -->
    <section class="sw-ending">
      <div class="sw-ending-inner">
        <p class="sw-eyebrow">The point is not a new stereotype</p>
        <h2 class="sw-ending-head">Context makes the picture larger.</h2>
        <p class="sw-ending-body">
          These eleven checks are a starting point, not a summary of a country. Follow the evidence, keep the uncertainty visible, and let Kazakhstan stay bigger than the shortcut assigned to it.
        </p>
        <a class="sw-cta" href="/myths">Open the full evidence library</a>
        <p class="sw-credits">
          Sources: United Nations, CIA World Factbook, UNESCO, World Bank, Bureau of National Statistics of Kazakhstan, Nuclear Threat Initiative, Encyclopedia Britannica.
        </p>
      </div>
    </section>

  </div>

  <script is:inline type="application/json" id="sw-data" set:html={JSON.stringify(storyData)}></script>
</BaseLayout>

<style>
/* ─── REGISTERED COLOR PROPERTIES (enables smooth transitions) ─── */
@property --sw-accent {
  syntax: '<color>';
  inherits: true;
  initial-value: #c5973e;
}
@property --sw-tint {
  syntax: '<color>';
  inherits: true;
  initial-value: transparent;
}

/* ─── RESET & TOKENS ─────────────────────────────────────── */
.sw {
  --sw-bg:    #080807;
  --sw-ink:   #f0ede5;
  --sw-muted: #7e7a73;
  --sw-line:  rgba(240,237,229,.12);
  --sw-gold:  #c5973e;
  --sw-red:   #d94f35;
  --sw-amber: #d4823a;
  --sw-accent: #c5973e;
  --sw-tint:   transparent;
  --sw-font-display: Georgia, 'Times New Roman', serif;
  --sw-font-ui:      ui-monospace, 'Menlo', monospace;
  background: var(--sw-bg);
  color: var(--sw-ink);
  margin: 0 calc(-1 * var(--page-pad, 0px));
  transition: --sw-accent .65s ease, --sw-tint .65s ease;
}

/* ─── TITLE SCREEN ───────────────────────────────────────── */
.sw-title {
  position: relative;
  min-height: 100svh;
  display: flex;
  align-items: center;
  overflow: hidden;
  padding: clamp(4rem,10vw,8rem) clamp(1.5rem,6vw,6rem);
}
.sw-title-inner {
  position: relative;
  z-index: 2;
  max-width: 780px;
}
.sw-eyebrow {
  font-family: var(--sw-font-ui);
  font-size: .68rem;
  text-transform: uppercase;
  letter-spacing: .12em;
  color: var(--sw-accent);
  margin: 0 0 1.8rem;
}
.sw-headline {
  font-family: var(--sw-font-display);
  font-size: clamp(3.8rem, 11vw, 9.5rem);
  font-weight: 400;
  line-height: .93;
  letter-spacing: -.04em;
  margin: 0 0 2rem;
  color: var(--sw-ink);
}
.sw-sub {
  font-size: clamp(1.1rem, 1.8vw, 1.35rem);
  line-height: 1.55;
  color: var(--sw-muted);
  max-width: 52ch;
  margin: 0 0 3rem;
}
.sw-scroll-hint {
  display: flex;
  align-items: center;
  gap: .6rem;
  color: var(--sw-muted);
  font-family: var(--sw-font-ui);
  font-size: .7rem;
  letter-spacing: .08em;
  text-transform: uppercase;
  animation: sw-bob 2.4s ease-in-out infinite;
}
@keyframes sw-bob {
  0%,100% { transform: translateY(0) }
  50%      { transform: translateY(6px) }
}
/* Background tag cloud */
.sw-title-grid {
  position: absolute;
  inset: 0;
  z-index: 1;
  display: flex;
  flex-wrap: wrap;
  align-content: center;
  gap: .8rem 1.2rem;
  padding: 4rem;
  pointer-events: none;
  opacity: .055;
  filter: blur(1px);
}
.sw-title-tag {
  font-family: var(--sw-font-display);
  font-size: clamp(.9rem, 2vw, 1.6rem);
  font-style: italic;
  white-space: nowrap;
  color: var(--sw-ink);
}

/* ─── SCROLL SHELL ───────────────────────────────────────── */
.sw-shell {
  position: relative;
  display: grid;
  grid-template-columns: minmax(0, 1.45fr) minmax(320px, .85fr);
  min-height: 100vh;
}
.sw-progress {
  position: fixed;
  z-index: 20;
  inset: 0 0 auto;
  height: 3px;
  background: rgba(255,255,255,.12);
  pointer-events: none;
}
.sw-progress-fill {
  display: block;
  width: 0;
  height: 100%;
  background: var(--sw-accent);
  box-shadow: 0 0 14px var(--sw-accent);
  transition: width .35s ease, background .35s ease;
}
@media (max-width: 860px) {
  .sw-shell { grid-template-columns: 1fr; }
}

/* ─── TEXT STEPS ─────────────────────────────────────────── */
.sw-steps {
  padding: 0 clamp(1.5rem,5vw,4rem);
}
.sw-step {
  min-height: 90vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 6rem 0;
  border-top: 1px solid var(--sw-line);
  opacity: 0;
  transform: translateY(20px);
  transition: opacity .5s ease, transform .5s ease;
}
.sw-step:first-child { border-top: 0; }
.sw-step.is-active {
  opacity: 1;
  transform: none;
}
.sw-step-meta {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 1.4rem;
}
.sw-counter {
  font-family: var(--sw-font-ui);
  font-size: .65rem;
  letter-spacing: .1em;
  color: var(--sw-accent);
  text-transform: uppercase;
}
.sw-tag {
  font-family: var(--sw-font-ui);
  font-size: .65rem;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: var(--sw-muted);
}
.sw-myth {
  font-family: var(--sw-font-display);
  font-style: italic;
  font-size: clamp(1.6rem, 3.5vw, 2.6rem);
  line-height: 1.18;
  letter-spacing: -.025em;
  color: var(--sw-ink);
  margin: 0 0 1.5rem;
  padding: 0;
  border: 0;
}
.sw-myth-mark { color: var(--sw-accent); }
.sw-rule {
  border: 0;
  border-top: 1px solid var(--sw-line);
  margin: 0 0 1.5rem;
}
.sw-lead {
  font-size: clamp(.95rem, 1.5vw, 1.1rem);
  line-height: 1.65;
  color: var(--sw-muted);
  max-width: 50ch;
  margin: 0 0 2rem;
}
.sw-stat {
  display: flex;
  align-items: baseline;
  gap: 1rem;
  flex-wrap: wrap;
  margin: 0 0 1.4rem;
  padding: 1.1rem 0;
  border-top: 1px solid var(--sw-line);
  border-bottom: 1px solid var(--sw-line);
}
.sw-stat-value {
  font-family: var(--sw-font-display);
  font-weight: 400;
  font-size: clamp(2rem, 4vw, 3rem);
  letter-spacing: -.04em;
  color: var(--sw-accent);
  line-height: 1;
}
.sw-stat-label {
  font-family: var(--sw-font-ui);
  font-size: .66rem;
  text-transform: uppercase;
  letter-spacing: .07em;
  color: var(--sw-muted);
  max-width: 30ch;
  line-height: 1.5;
}
.sw-verdict {
  display: inline-block;
  font-family: var(--sw-font-ui);
  font-size: .68rem;
  font-weight: 700;
  letter-spacing: .14em;
  text-transform: uppercase;
  padding: .35rem .8rem;
  border-radius: 2px;
  margin: 0 0 1.2rem;
}
.sw-verdict--false     { background: color-mix(in srgb, var(--sw-red)   14%, transparent); color: var(--sw-red); }
.sw-verdict--misleading{ background: color-mix(in srgb, var(--sw-amber) 14%, transparent); color: var(--sw-amber); }
.sw-link {
  font-family: var(--sw-font-ui);
  font-size: .72rem;
  letter-spacing: .06em;
  text-transform: uppercase;
  color: var(--sw-accent);
  text-decoration: none;
  transition: opacity .2s;
  align-self: flex-start;
}
.sw-link:hover { opacity: .7; }

/* ─── PATTERN STEP ───────────────────────────────────────── */
.sw-step--pattern { min-height: auto; padding: 8rem 0; }
.sw-pattern-head {
  font-family: var(--sw-font-display);
  font-size: clamp(2rem, 4vw, 3.8rem);
  font-weight: 400;
  line-height: 1.05;
  letter-spacing: -.035em;
  margin: 0 0 1.2rem;
}
.sw-pattern-grid {
  display: grid;
  gap: 1rem;
  margin-top: 2rem;
}
.sw-pattern-card {
  padding: 1.4rem;
  border: 1px solid var(--sw-line);
  border-radius: 6px;
}
.sw-pattern-n {
  font-family: var(--sw-font-ui);
  font-size: .6rem;
  letter-spacing: .1em;
  color: var(--sw-accent);
  text-transform: uppercase;
  display: block;
  margin-bottom: .5rem;
}
.sw-pattern-card h3 {
  font-size: 1rem;
  font-weight: 600;
  letter-spacing: -.01em;
  margin: 0 0 .5rem;
  color: var(--sw-ink);
}
.sw-pattern-card p {
  font-size: .88rem;
  line-height: 1.6;
  color: var(--sw-muted);
  margin: 0;
}

/* ─── VISUAL PANEL ───────────────────────────────────────── */
.sw-visual-wrap {
  position: relative;
}
.sw-visual {
  position: sticky;
  top: 0;
  height: 100svh;
  overflow: hidden;
  background: #111;
}
.sw-visual::after {
  content: "";
  position: absolute;
  inset: 0;
  z-index: 5;
  pointer-events: none;
  opacity: .14;
  mix-blend-mode: screen;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 180 180' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.38'/%3E%3C/svg%3E");
  animation: sw-grain .28s steps(2) infinite;
}
@keyframes sw-grain {
  0% { transform: translate(0,0); }
  25% { transform: translate(1%, -1%); }
  50% { transform: translate(-1%, 1%); }
  75% { transform: translate(1%, 1%); }
  100% { transform: translate(-1%, -1%); }
}
/* Photos */
.sw-photo {
  position: absolute;
  inset: 0;
  opacity: 0;
  visibility: hidden;
  z-index: 0;
  transition: opacity .8s cubic-bezier(.2,.7,.2,1), visibility 0s linear .8s;
}
.sw-photo.is-active {
  opacity: 1;
  visibility: visible;
  z-index: 1;
  transition-delay: 0s;
}
.sw-photo.is-swapping { opacity: .12; transform: scale(.985); }
.sw-photo.is-swapping img { transform: scale(1.06); }
.sw-photo img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  transform: scale(1.06);
  filter: saturate(.82) contrast(1.06);
  transition: transform 1.8s cubic-bezier(.2,.7,.2,1), filter 1.1s ease;
}
.sw-photo.is-active img { transform: scale(1); filter: saturate(1) contrast(1.04); }
/* Per-myth color tint layer */
.sw-photo-tint {
  position: absolute;
  inset: 0;
  z-index: 1;
  background: var(--sw-tint);
  pointer-events: none;
  mix-blend-mode: multiply;
}
/* Gradient overlays — lightened so photos are visible */
.sw-photo-overlay {
  position: absolute;
  left: 0;
  right: 0;
  z-index: 2;
  pointer-events: none;
}
.sw-photo-overlay--top {
  top: 0;
  height: 40%;
  background: linear-gradient(to bottom, rgba(8,8,7,.6) 0%, transparent 100%);
}
.sw-photo-overlay--bottom {
  bottom: 0;
  height: 50%;
  background: linear-gradient(to top, rgba(8,8,7,.72) 0%, rgba(8,8,7,.3) 55%, transparent 100%);
}
/* Myth text on photo */
.sw-photo-myth {
  position: absolute;
  inset: 0;
  z-index: 3;
  display: flex;
  align-items: flex-end;
  padding: 5rem 2.5rem;
  pointer-events: none;
}
.sw-photo-myth-text {
  font-family: var(--sw-font-display);
  font-style: italic;
  font-size: clamp(1.4rem, 2.8vw, 2.2rem);
  line-height: 1.22;
  letter-spacing: -.025em;
  color: rgba(240,237,229,.6);
  max-width: 28ch;
  transition: opacity .45s ease, transform .45s ease;
}
/* HUD */
.sw-hud {
  position: absolute;
  left: 2rem;
  right: 2rem;
  z-index: 4;
  display: flex;
  align-items: center;
  justify-content: space-between;
  pointer-events: none;
}
.sw-hud--top { top: 1.5rem; }
.sw-hud--bottom { bottom: 1.5rem; }
.sw-hud-counter,
.sw-hud-label,
.sw-hud-sources,
.sw-hud-scroll {
  font-family: var(--sw-font-ui);
  font-size: .64rem;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: rgba(240,237,229,.45);
  transition: color .3s;
}
.sw-hud-sources { color: rgba(240,237,229,.62); }
.sw-hud-counter { color: var(--sw-accent); }
.sw-hud-verdict {
  font-family: var(--sw-font-ui);
  font-size: .68rem;
  font-weight: 700;
  letter-spacing: .12em;
  text-transform: uppercase;
  transition: color .3s;
}
.sw-hud-verdict[data-verdict="false"]      { color: var(--sw-red); }
.sw-hud-verdict[data-verdict="misleading"] { color: var(--sw-amber); }

/* ─── ENDING ─────────────────────────────────────────────── */
.sw-ending {
  padding: clamp(5rem,12vw,11rem) clamp(1.5rem,6vw,6rem);
  border-top: 1px solid var(--sw-line);
}
.sw-ending-inner { max-width: 680px; }
.sw-ending-head {
  font-family: var(--sw-font-display);
  font-size: clamp(2.4rem, 6vw, 5.5rem);
  font-weight: 400;
  line-height: .96;
  letter-spacing: -.045em;
  margin: .6rem 0 1.5rem;
}
.sw-ending-body {
  font-size: clamp(1rem, 1.6vw, 1.2rem);
  line-height: 1.65;
  color: var(--sw-muted);
  max-width: 52ch;
  margin: 0 0 2.5rem;
}
.sw-cta {
  display: inline-block;
  font-family: var(--sw-font-ui);
  font-size: .8rem;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--sw-gold);
  text-decoration: none;
  padding: .85rem 1.8rem;
  border: 1px solid color-mix(in srgb, var(--sw-gold) 35%, transparent);
  border-radius: 3px;
  transition: background .2s, color .2s, border-color .2s;
}
.sw-cta:hover {
  background: var(--sw-gold);
  color: var(--sw-bg);
}
.sw-credits {
  margin-top: 2.5rem;
  font-family: var(--sw-font-ui);
  font-size: .6rem;
  letter-spacing: .06em;
  color: var(--sw-muted);
  line-height: 1.7;
  max-width: 60ch;
  opacity: .6;
}

/* ─── MOBILE ─────────────────────────────────────────────── */
@media (max-width: 860px) {
  .sw-shell { display: block; }
  .sw-visual-wrap { height: 0; }
  .sw-visual {
    position: fixed;
    inset: 0;
    height: 100svh;
    z-index: 0;
    opacity: 0;
    transition: opacity .4s;
  }
  .sw-visual.mobile-visible { opacity: 1; }
  .sw-steps {
    position: relative;
    z-index: 2;
    padding-top: 55vh;
  }
  .sw-step {
    background: linear-gradient(
      to bottom,
      transparent 0%,
      color-mix(in srgb, var(--sw-bg) 88%, transparent) 10%,
      var(--sw-bg) 25%,
      var(--sw-bg) 75%,
      color-mix(in srgb, var(--sw-bg) 88%, transparent) 90%,
      transparent 100%
    );
    min-height: 80vh;
  }
  .sw-photo-myth { display: none; }
  .sw-steps { padding-inline: 1.25rem; }
}

/* ─── REDUCED MOTION ─────────────────────────────────────── */
@media (prefers-reduced-motion: reduce) {
  .sw-step, .sw-photo, .sw-photo-myth-text,
  .sw-hud-counter, .sw-hud-verdict, .sw-cta { transition: none; }
  .sw-progress-fill { transition: none; }
  .sw-scroll-hint { animation: none; }
  .sw-visual::after { animation: none; }
  .sw-photo img { transition: none; }
}
</style>

<script>
  import scrollama from "scrollama";

  const dataEl = document.querySelector<HTMLScriptElement>("#sw-data");
  if (!dataEl) throw new Error("sw-data missing");

  type MythEntry = {
    slug: string; title: string; statement: string;
    verdict: "false" | "misleading"; heroImage: string;
    stat: string; statLabel: string; lead: string;
    sourceCount: number; reviewedAt: string;
  };
  const data: MythEntry[] = JSON.parse(dataEl.textContent || "[]");

  // Per-myth accent colors — each myth has its own visual identity
  const accentColors: Record<string, string> = {
    "borat":              "#d4924a",  // warm amber — film/entertainment
    "capital-astana":     "#5899d4",  // sky blue   — institutional capital
    "economy-oil":        "#3fb5a0",  // teal       — minerals/resources
    "ethnic-diversity":   "#c8607a",  // rose       — people, warmth
    "kazakh-and-russian": "#8f86d8",  // lavender   — language, scripts
    "nuclear-weapons":    "#d44a25",  // red-orange — danger, nuclear history
    "only-steppe":        "#52a868",  // forest     — nature, landscapes
    "part-of-russia":     "#4872b5",  // steel blue — sovereignty, statehood
    "yurts":              "#c47a50",  // terracotta — heritage, felt
  };

  // Tint overlays: accent at ~18% opacity (hex 2e ≈ 18%)
  const tintColors: Record<string, string> = {
    "borat":              "#d4924a2e",
    "capital-astana":     "#5899d42e",
    "economy-oil":        "#3fb5a02e",
    "ethnic-diversity":   "#c8607a2e",
    "kazakh-and-russian": "#8f86d82e",
    "nuclear-weapons":    "#d44a252e",
    "only-steppe":        "#52a8682e",
    "part-of-russia":     "#4872b52e",
    "yurts":              "#c47a502e",
  };

  const photoStage = document.querySelector<HTMLElement>("[data-photo-stage]");
  const storyImage = document.querySelector<HTMLImageElement>("[data-story-image]");
  let loadedImage = 0;
  const photoTint  = document.querySelector<HTMLElement>("[data-photo-tint]");
  const mythText   = document.querySelector<HTMLElement>("[data-photo-myth-text]");
  const hudCounter = document.querySelector<HTMLElement>("[data-hud-counter]");
  const hudLabel   = document.querySelector<HTMLElement>("[data-hud-label]");
  const hudVerdict = document.querySelector<HTMLElement>("[data-hud-verdict]");
  const hudSources = document.querySelector<HTMLElement>("[data-hud-sources]");
  const hudScroll  = document.querySelector<HTMLElement>("[data-hud-scroll]");
  const visual     = document.querySelector<HTMLElement>("[data-visual]");
  const swRoot     = document.querySelector<HTMLElement>(".sw");
  const steps      = [...document.querySelectorAll<HTMLElement>(".sw-step")];
  const progress   = document.querySelector<HTMLElement>("[data-story-progress]");
  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  const isMobile = () => window.innerWidth <= 860;

  function activate(index: number | null) {
    // photos
    if (index !== null && storyImage && photoStage && index !== loadedImage) {
      const next = data[index];
      const swap = () => {
        storyImage.src = next.heroImage;
        loadedImage = index;
        photoStage.classList.remove("is-swapping");
        photoStage.classList.add("is-active");
      };
      if (reducedMotion) swap();
      else {
        photoStage.classList.add("is-swapping");
        window.setTimeout(swap, 220);
      }
    }

    // steps: only fade in active on desktop; always show on mobile
    steps.forEach((s) => {
      const stepIdx = s.dataset.step;
      const match = stepIdx === "pattern"
        ? index === null
        : Number(stepIdx) === index;
      s.classList.toggle("is-active", match || isMobile());
    });

    if (index === null) {
      if (progress) progress.style.width = "100%";
      if (hudScroll) hudScroll.textContent = "";
      // reset accent to gold when at pattern step
      if (swRoot) {
        swRoot.style.setProperty("--sw-accent", "#c5973e");
        swRoot.style.setProperty("--sw-tint", "transparent");
      }
      return;
    }

    const m = data[index];
    if (!m) return;
    if (progress) progress.style.width = `${((index + 1) / data.length) * 100}%`;

    // Apply per-myth color identity
    const accent = accentColors[m.slug] ?? "#c5973e";
    const tint   = tintColors[m.slug]   ?? "transparent";
    if (swRoot) {
      swRoot.style.setProperty("--sw-accent", accent);
      swRoot.style.setProperty("--sw-tint", tint);
    }
    // Also update tint overlay directly (fallback for browsers without @property)
    if (photoTint) photoTint.style.background = tint;

    if (mythText) {
      if (reducedMotion) {
        mythText.textContent = `"${m.statement}"`;
      } else {
        mythText.style.opacity = "0";
        mythText.style.transform = "translateY(8px)";
        requestAnimationFrame(() => {
          setTimeout(() => {
            mythText.textContent = `"${m.statement}"`;
            mythText.style.opacity = "";
            mythText.style.transform = "";
          }, 180);
        });
      }
    }
    if (hudCounter) hudCounter.textContent = `${String(index + 1).padStart(2, "0")} / ${data.length}`;
    if (hudLabel)   hudLabel.textContent   = m.title.replace(/^Kazakhstan[' s]*/i, "");
    if (hudVerdict) {
      hudVerdict.textContent = m.verdict === "false" ? "FALSE" : "MISLEADING";
      hudVerdict.dataset.verdict = m.verdict;
    }
    if (hudSources) hudSources.textContent = `${m.sourceCount} sources · ${m.reviewedAt}`;
    if (hudScroll)  hudScroll.textContent  = index < data.length - 1 ? "Scroll to continue" : "End of myths";

    // mobile: show visual panel
    if (isMobile() && visual) visual.classList.add("mobile-visible");
  }

  // Mobile: hide visual after pattern step
  function deactivateMobile() {
    if (isMobile() && visual) visual.classList.remove("mobile-visible");
  }

  // Initial state
  if (isMobile()) {
    steps.forEach(s => s.classList.add("is-active"));
    activate(0);
  } else {
    activate(0);
    steps[0]?.classList.add("is-active");
  }

  const scroller = scrollama();
  scroller
    .setup({ step: ".sw-step", offset: isMobile() ? 0.4 : 0.5, progress: false })
    .onStepEnter(({ element }) => {
      const step = element.dataset.step;
      if (step === "pattern") {
        deactivateMobile();
        steps.forEach(s => s.classList.toggle("is-active", s.dataset.step === "pattern" || isMobile()));
      } else {
        activate(Number(step));
      }
    });

  window.addEventListener("resize", () => scroller.resize(), { passive: true });
</script>
