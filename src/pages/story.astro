</style>

<script>
  import scrollama from "scrollama";

  const dataEl = document.querySelector<HTMLScriptElement>("#sw-data");
  if (!dataEl) throw new Error("sw-data missing");

  type MythEntry = {
    slug: string; title: string; statement: string;
    verdict: "false" | "misleading"; heroImage: string; heroAlt?: string;
    stat: string; statLabel: string; lead: string;
    sourceCount: number; reviewedAt: string;
  };
  const data: MythEntry[] = JSON.parse(dataEl.textContent || "[]");

  // Per-myth accent colors — each myth has its own visual identity
  const accentColors: Record<string, string> = {
    "borat":              "#d4924a",  // warm amber — film/entertainment
    "capital-astana":     "#5899d4",  // sky blue   — institutional capital
    "economy-oil":        "#3fb5a0",  // teal       — minerals/resources
    "ethnic-diversity":   "#c8607a",  // rose       — people, warmth
    "kazakh-and-russian": "#8f86d8",  // lavender   — language, scripts
    "nuclear-weapons":    "#d44a25",  // red-orange — danger, nuclear history
    "nuclear-energy-weapons": "#e07a35",
    "only-steppe":        "#52a868",  // forest     — nature, landscapes
    "part-of-russia":     "#4872b5",  // steel blue — sovereignty, statehood
    "yurts":              "#c47a50",  // terracotta — heritage, felt
    "secular-muslim":     "#b08bd1",
    "aral-sea-gone":      "#4e9da6",
    "landlocked-isolated": "#7c9b78",
    "internet-closed":    "#d05f70",
    "giant-door":         "#9173b5",
    "horse-meat-kumys":   "#d18a52",
    "kazakhstan-memes":   "#e0b04f",
  };

  // Tint overlays: accent at ~18% opacity (hex 2e ≈ 18%)
  const tintColors: Record<string, string> = {
    "borat":              "#d4924a2e",
    "capital-astana":     "#5899d42e",
    "economy-oil":        "#3fb5a02e",
    "ethnic-diversity":   "#c8607a2e",
    "kazakh-and-russian": "#8f86d82e",
    "nuclear-weapons":    "#d44a252e",
    "nuclear-energy-weapons": "#e07a352e",
    "only-steppe":        "#52a8682e",
    "part-of-russia":     "#4872b52e",
    "yurts":              "#c47a502e",
    "secular-muslim":     "#b08bd12e",
    "aral-sea-gone":      "#4e9da62e",
    "landlocked-isolated": "#7c9b782e",
    "internet-closed":    "#d05f702e",
    "giant-door":         "#9173b52e",
    "horse-meat-kumys":   "#d18a522e",
    "kazakhstan-memes":   "#e0b04f2e",
  };

  const photoStage = document.querySelector<HTMLElement>("[data-photo-stage]");
  const storyImage = document.querySelector<HTMLImageElement>("[data-story-image]");
  let loadedImage = 0;
  let swapToken = 0;
  const photoTint  = document.querySelector<HTMLElement>("[data-photo-tint]");
  const mythText   = document.querySelector<HTMLElement>("[data-photo-myth-text]");
  const hudCounter = document.querySelector<HTMLElement>("[data-hud-counter]");
  const hudLabel   = document.querySelector<HTMLElement>("[data-hud-label]");
  const hudVerdict = document.querySelector<HTMLElement>("[data-hud-verdict]");
  const hudSources = document.querySelector<HTMLElement>("[data-hud-sources]");
  const hudScroll  = document.querySelector<HTMLElement>("[data-hud-scroll]");
  const visual     = document.querySelector<HTMLElement>("[data-visual]");
  const swRoot     = document.querySelector<HTMLElement>(".sw");
  const steps      = [...document.querySelectorAll<HTMLElement>(".sw-step")];
  const progress   = document.querySelector<HTMLElement>("[data-story-progress]");
  const progressLabel = document.querySelector<HTMLElement>("[data-story-progress-label]");
  const chapterLinks = [...document.querySelectorAll<HTMLAnchorElement>("[data-chapter-link]")];
  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const resumeButton = document.querySelector<HTMLButtonElement>("[data-resume]");
  const resumeNumber = document.querySelector<HTMLElement>("[data-resume-number]");
  const storyKey = "qazaq-lens-story-progress";
  let savedProgress = 0; try { savedProgress = Number.parseInt(localStorage.getItem(storyKey) ?? "0", 10); } catch {}
  if (savedProgress > 0 && savedProgress < data.length && resumeButton && resumeNumber) {
    resumeButton.hidden = false;
    resumeButton.style.display = "inline-block";
    resumeNumber.textContent = `${String(savedProgress + 1).padStart(2, "0")} / ${data.length}`;
    resumeButton.addEventListener("click", () => document.querySelector(`[data-step="${savedProgress}"]`)?.scrollIntoView({ behavior: reducedMotion ? "auto" : "smooth" }));
  }
  const quizQuestions = [...document.querySelectorAll<HTMLElement>("[data-quiz-question]")];
  const quizFeedback = document.querySelector<HTMLElement>("[data-quiz-feedback]");
  const quizResult = document.querySelector<HTMLElement>("[data-quiz-result]");
  const quizScore = document.querySelector<HTMLElement>("[data-quiz-score]");
  let quizIndex = 0; let quizCorrect = 0;
  quizQuestions.forEach((question, questionIndex) => question.querySelectorAll<HTMLButtonElement>("[data-answer]").forEach((button) => button.addEventListener("click", () => {
    if (questionIndex !== quizIndex) return;
    const correct = button.dataset.answer === "correct";
    if (correct) quizCorrect++;
    question.querySelectorAll<HTMLButtonElement>("button").forEach((item) => { item.disabled = true; if (item.dataset.answer === "correct") item.classList.add("is-correct"); });
    button.classList.add(correct ? "is-correct" : "is-wrong");
    if (quizFeedback) quizFeedback.textContent = correct ? "Correct — the important distinction is context." : "Not quite — look for the distinction between a real fact and an overgeneralisation.";
    window.setTimeout(() => { question.hidden = true; quizIndex++; const next = quizQuestions[quizIndex]; if (next) next.hidden = false; else if (quizResult && quizScore) { quizScore.textContent = `${quizCorrect} / 3`; quizResult.hidden = false; } }, 650);
  })));

  // Warm the full visual sequence in the background so a scroll never waits
  // for the next photograph to arrive from the network.
  data.slice(1).forEach((entry) => {
    const image = new Image();
    image.decoding = "async";
    image.src = entry.heroImage;
  });

  const isMobile = () => window.innerWidth <= 860;

  function activate(index: number | null) {
    // photos
    if (index !== null && storyImage && photoStage && index !== loadedImage) {
      const next = data[index];
      const token = ++swapToken;
      const swap = () => {
        if (token !== swapToken) return;
        photoStage.classList.add("is-swapping");
        storyImage.style.opacity = "0";
        const candidate = new Image();
        candidate.decoding = "async";
        candidate.onload = () => {
          if (token !== swapToken) return;
          storyImage.src = next.heroImage;
          storyImage.alt = next.heroAlt || `${next.title} visual evidence`;
          storyImage.style.opacity = "";
          loadedImage = index;
          photoStage.classList.remove("is-swapping");
          photoStage.classList.add("is-active");
        };
        candidate.onerror = () => {
          if (token === swapToken) { storyImage.style.opacity = ""; photoStage.classList.remove("is-swapping"); }
        };
        candidate.src = next.heroImage;
      };
      if (reducedMotion) swap();
      else {
        photoStage.classList.add("is-swapping");
        window.setTimeout(swap, 30);
      }
    }

    // steps: only fade in active on desktop; always show on mobile
    steps.forEach((s) => {
      const stepIdx = s.dataset.step;
      const match = stepIdx === "pattern"
        ? index === null
        : Number(stepIdx) === index;
      s.classList.toggle("is-active", match || isMobile());
    });

    if (index === null) {
      if (progress) progress.style.width = "100%";
      if (progressLabel) progressLabel.textContent = `Pattern · you made it through all ${data.length} checks`;
      if (hudScroll) hudScroll.textContent = "";
      // reset accent to gold when at pattern step
      if (swRoot) {
        swRoot.style.setProperty("--sw-accent", "#c5973e");
        swRoot.style.setProperty("--sw-tint", "transparent");
      }
      return;
    }

    const m = data[index];
    if (!m) return;
    try { localStorage.setItem(storyKey, String(index)); } catch {}
    chapterLinks.forEach((link) => link.classList.toggle("is-active", Number(link.dataset.chapterLink) === index));
    const hash = `#story-${m.slug}`;
    if (location.hash !== hash && !document.documentElement.classList.contains("is-jumping")) history.replaceState(null, "", hash);
    if (progress) progress.style.width = `${((index + 1) / data.length) * 100}%`;
    if (progressLabel) {
      const left = data.length - index - 1;
      progressLabel.textContent = `${String(index + 1).padStart(2, "0")} / ${data.length} · ${left ? `${left} left` : "last check"}`;
    }

    // Apply per-myth color identity
    const accent = accentColors[m.slug] ?? "#c5973e";
    const tint   = tintColors[m.slug]   ?? "transparent";
    if (swRoot) {
      swRoot.style.setProperty("--sw-accent", accent);
      swRoot.style.setProperty("--sw-tint", tint);
    }
    // Also update tint overlay directly (fallback for browsers without @property)
    if (photoTint) photoTint.style.background = tint;

    if (mythText) {
      if (reducedMotion) {
        mythText.textContent = `"${m.statement}"`;
      } else {
        mythText.style.opacity = "0";
        mythText.style.transform = "translateY(5px)";
        requestAnimationFrame(() => {
          setTimeout(() => {
            mythText.textContent = `"${m.statement}"`;
            mythText.style.opacity = "";
            mythText.style.transform = "";
          }, 70);
        });
      }
    }
    if (hudCounter) hudCounter.textContent = `${String(index + 1).padStart(2, "0")} / ${data.length}`;
    if (hudLabel)   hudLabel.textContent   = m.title.replace(/^Kazakhstan[' s]*/i, "");
    if (hudVerdict) {
      hudVerdict.textContent = m.verdict === "false" ? "FALSE" : "MISLEADING";
      hudVerdict.dataset.verdict = m.verdict;
    }
    if (hudSources) hudSources.textContent = `${m.sourceCount} sources · ${m.reviewedAt}`;
    if (hudScroll)  hudScroll.textContent  = index < data.length - 1 ? "Scroll to continue" : "End of myths";

    // mobile: show visual panel
    if (isMobile() && visual) visual.classList.add("mobile-visible");
  }

  // Mobile: hide visual after pattern step
  function deactivateMobile() {
    if (isMobile() && visual) visual.classList.remove("mobile-visible");
  }

  // Initial state
  if (isMobile()) {
    steps.forEach(s => s.classList.add("is-active"));
    activate(0);
  } else {
    activate(0);
    steps[0]?.classList.add("is-active");
  }

  const initialHash = location.hash.replace(/^#story-/, "");
  const initialIndex = data.findIndex((entry) => entry.slug === initialHash);
  if (initialIndex >= 0) window.setTimeout(() => document.querySelector(`[data-step="${initialIndex}"]`)?.scrollIntoView({ behavior: "auto" }), 0);

  const scroller = scrollama();
  scroller
    .setup({ step: ".sw-step", offset: isMobile() ? 0.4 : 0.5, progress: false })
    .onStepEnter(({ element }) => {
      const step = element.dataset.step;
      if (step === "pattern") {
        deactivateMobile();
        steps.forEach(s => s.classList.toggle("is-active", s.dataset.step === "pattern" || isMobile()));
      } else {
        activate(Number(step));
      }
    });

  window.addEventListener("resize", () => scroller.resize(), { passive: true });
</script>
