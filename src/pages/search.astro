---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getVisibleMyths } from "../lib/content";
const myths = await getVisibleMyths();
const records = myths.flatMap((myth) => [
  { type: "article", title: myth.data.title, text: `${myth.data.title} ${myth.data.summary} ${myth.data.topics.join(" ")}`, href: `/myths/${myth.data.slug}` },
  ...myth.data.claims.map((claim) => ({ type: "claim", title: claim.id, text: claim.statement, href: `/myths/${myth.data.slug}#claim-${claim.id}` })),
  ...myth.data.sources.map((source) => ({ type: "source", title: source.title, text: `${source.title} ${source.publisher}`, href: source.url })),
]);
---
<BaseLayout title="Search evidence" description="Search Qazaq Lens articles, claims and source records.">
  <main class="wrap-wide page-hero"><p class="eyebrow">Evidence search</p><h1>Search the evidence layer.</h1><p class="lead">Find an article, a registered claim or the source behind a conclusion.</p><label class="search-field global-search"><span class="visually-hidden">Search articles, claims and sources</span><input type="search" placeholder="Try: Aral Sea, Baikonur, language…" data-evidence-search autofocus /></label><p class="library-count" data-search-count>{records.length} records</p></main>
  <section class="wrap-wide section-block"><div class="search-results" data-search-results>{records.map((record)=><a class="search-result" data-search-record data-search-text={record.text.toLowerCase()} href={record.href}><span class="tag">{record.type}</span><h2>{record.title}</h2><p>{record.text}</p></a>)}</div><p class="empty-state" data-search-empty hidden>No matching evidence. Try a broader term.</p></section>
  <script is:inline>
    const input = document.querySelector("[data-evidence-search]"); const records = [...document.querySelectorAll("[data-search-record]")]; const count = document.querySelector("[data-search-count]"); const empty = document.querySelector("[data-search-empty]"); const apply = () => { const query = (input?.value || "").trim().toLowerCase(); let visible = 0; records.forEach((record) => { const show = !query || (record.dataset.searchText || "").includes(query); record.hidden = !show; if (show) visible++; }); if (count) count.textContent = `${visible} matching records`; if (empty) empty.hidden = visible > 0; const url = new URL(location.href); query ? url.searchParams.set("q", query) : url.searchParams.delete("q"); history.replaceState({}, "", url); }; const initial = new URL(location.href).searchParams.get("q") || ""; if (input) input.value = initial; input?.addEventListener("input", apply); apply();
  </script>
</BaseLayout>
