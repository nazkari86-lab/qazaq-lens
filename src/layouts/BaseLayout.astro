---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  type?: "website" | "article";
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}
const { title, description, ogImage = "/og/default.png", type = "website", noindex = false, jsonLd } = Astro.props;
const site = Astro.site ?? new URL("https://qazaq-lens.nazkari86.workers.dev");
const canonicalURL = new URL(Astro.url.pathname, site);
const ogImageURL = new URL(ogImage, site);
const fullTitle = title === "Qazaq Lens" ? title : `${title} · Qazaq Lens`;
const orgJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Qazaq Lens",
  url: site.toString(),
  description: "Independent, sourced cultural context about Kazakhstan for international readers.",
  sameAs: [site.toString()],
};
const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Qazaq Lens",
  url: site.toString(),
  potentialAction: {
    "@type": "SearchAction",
    target: { "@type": "EntryPoint", urlTemplate: `${site.toString()}myths?q={search_term_string}` },
    "query-input": "required name=search_term_string",
  },
};
---
<!doctype html>
<html lang="en" data-theme="system">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#f3efe4" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#101719" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="alternate" type="application/rss+xml" title="Qazaq Lens" href="/rss.xml" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="prefetch" href="/myths/" as="document" />
    <link rel="prefetch" href="/start/" as="document" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Qazaq Lens" />
    {noindex ? <meta name="robots" content="noindex, nofollow" /> : <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large" />}

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${title} — Qazaq Lens`} />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="Qazaq Lens" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />
    {jsonLd && <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    <script is:inline>
      try {
        const saved = localStorage.getItem("qazaq-lens-theme");
        if (saved === "light" || saved === "dark") document.documentElement.dataset.theme = saved;
      } catch {}
    </script>
  </head>
  <body>
    <Header />
    <main id="main-content" tabindex="-1"><slot /></main>
    <Footer />
    <script>
      const revealItems = document.querySelectorAll("[data-reveal]");
      if ("IntersectionObserver" in window && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        const revealObserver = new IntersectionObserver((entries, observer) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-revealed");
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.12, rootMargin: "0px 0px -8%" });
        revealItems.forEach((item) => revealObserver.observe(item));
      } else {
        revealItems.forEach((item) => item.classList.add("is-revealed"));
      }
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", () => navigator.serviceWorker.register("/sw.js").catch(() => undefined));
      }
    </script>
  </body>
</html>
