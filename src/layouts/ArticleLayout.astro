---
import BaseLayout from "./BaseLayout.astro";
import VerdictBox from "../components/VerdictBox.astro";
import SourceList from "../components/SourceList.astro";
import ClaimLedger from "../components/ClaimLedger.astro";
import Changelog from "../components/Changelog.astro";
import LastReviewed from "../components/LastReviewed.astro";
import ReportError from "../components/ReportError.astro";
import ShareTools from "../components/ShareTools.astro";
import TableOfContents from "../components/TableOfContents.astro";
import ReadingProgress from "../components/ReadingProgress.astro";
import KeyTakeaways from "../components/KeyTakeaways.astro";
import RelatedMyths from "../components/RelatedMyths.astro";
import WhyThisMatters from "../components/WhyThisMatters.astro";
import Comments from "../components/Comments.astro";
import BookmarkButton from "../components/BookmarkButton.astro";
import ReadingMode from "../components/ReadingMode.astro";
import EvidenceVisual from "../components/EvidenceVisual.astro";
import EvidenceHealth from "../components/EvidenceHealth.astro";
import KnowledgeCheck from "../components/KnowledgeCheck.astro";
import EvidenceCard from "../components/EvidenceCard.astro";
import SelectionAnnotation from "../components/SelectionAnnotation.astro";
import type { MythEntry } from "../lib/content";

interface Source { id: string; title: string; publisher: string; author?: string; publishedAt?: string; accessedAt: Date; url: string; archivedUrl?: string; language: string; type: "primary" | "academic" | "official" | "journalistic" | "background"; }
interface Claim { id: string; statement: string; kind: "fact" | "interpretation" | "reported-view" | "disputed"; significance: "critical" | "supporting"; confidence: "high" | "medium" | "low"; sourceIds: string[]; note?: string; }
interface Change { date: Date; summary: string }
interface Heading { depth: number; slug: string; text: string }
interface Props {
  title: string; mythStatement: string; summary: string; verdict: "false" | "misleading" | "partly-true" | "outdated" | "unverified" | "disputed";
  slug?: string;
  publicationStatus: "beta" | "reviewed"; publishedAt: Date; lastReviewedAt: Date; author: string; reviewStatus: string;
  reviewedBy: string[]; sources: Source[]; claims: Claim[]; changelog: Change[]; keyTakeaways: string[]; topics: string[];
  headings: Heading[]; readingMinutes: number; related: MythEntry[]; ogImage?: string; draft?: boolean;
  heroImage?: string; heroImageAlt?: string; heroImageCredit?: string; heroImageCreditUrl?: string;
}
const props = Astro.props;
const whyThisMatters: Record<string, string> = {
  "part-of-russia": "This is a question of sovereignty and geography, not just historical vocabulary. Confusing a UN member state with a neighbouring country erases Kazakhstan's independent institutions and political agency.",
  "kazakh-and-russian": "Language classification shapes how readers understand identity, bilingualism and language policy. Shared public space or Cyrillic script does not make two different language families one language.",
  "nuclear-weapons": "The distinction between a former nuclear arsenal and a current nuclear-armed state changes how Kazakhstan's security history and non-proliferation record are understood.",
  "economy-oil": "A fair description must hold two facts together: extractive industries remain structurally important, while manufacturing, agriculture, logistics, services and finance also shape the economy.",
  "baikonur": "Baikonur is a useful case where geography, sovereignty, leasing and day-to-day operation point in different directions. A Russian launch does not make the cosmodrome Russian territory.",
  "ethnic-diversity": "Citizenship, ethnicity, language and national identity are not interchangeable categories. Careful wording avoids turning a majority population into a claim that everyone shares one background.",
  "borat": "Borat is a gateway into the subject, but a film character is not evidence about a country's people, institutions or culture. The distinction matters because entertainment can become a country's default international reference.",
  "capital-astana": "This is a practical, high-search confusion created by a capital move and several name changes. Getting it right is a basic test of present-day geographic literacy.",
  "yurts": "The yurt remains living heritage and is still used in cultural, festive and practical settings. The correction is not that yurts disappeared; it is that they are not the majority's everyday housing.",
  "only-steppe": "Landscape shorthand hides the country's ecological range and its urban life. Mountains, forests, lakes, canyons, Caspian shorelines, deserts and cities all belong in the picture.",
  "silk-roads": "The stronger historical question is whether Kazakhstan was connected to cities, trade and cultural exchange. Archaeology and the UNESCO corridor show a network crossing the region, not an empty gap.",
  "internet-closed": "A connected public sphere and restrictions on online speech can exist at the same time. Neither fully open nor fully closed describes the lived digital environment.",
  "secular-muslim": "Religious identity and secular constitutional law describe different layers of society. Neither a mosque nor a legal principle is the whole country.",
  "nuclear-energy-weapons": "Civilian nuclear power, nuclear testing and nuclear weapons are connected in public memory but are not the same technical or legal category.",
  "giant-door": "Viral imagery can be culturally powerful without being archaeological evidence. This case tests how to handle uncertainty before repeating a spectacular claim.",
  "aral-sea-gone": "The Aral Sea story requires two truths at once: catastrophic ecological loss and partial northern recovery. One image cannot carry that whole history.",
  "landlocked-isolated": "Being landlocked is a geographic condition, not a measure of contact. Ports, railways, pipelines and trade corridors separate access from isolation.",
  "kazakhstan-memes": "Memes reveal what people remix and debate online, not what every citizen believes. Digital folklore is evidence of discourse, not a national personality test.",
  "horse-meat-kumys": "Food heritage can be important without defining every contemporary diet. The distinction protects cultural specificity and everyday complexity.",
};
const whyWeChecked: Record<string, string> = {
  "part-of-russia": "Selected because this shortcut repeatedly appears in international media, travel discussions and geopolitical commentary, and confuses Soviet history with present sovereignty.",
  "kazakh-and-russian": "Selected because language-family confusion is common in international coverage and directly affects how readers interpret Kazakhstan's bilingual public life.",
  "nuclear-weapons": "Selected because Kazakhstan's inherited Soviet arsenal is frequently used as shorthand for its current identity, despite the country's disarmament history.",
  "economy-oil": "Selected because oil-only descriptions recur in business and travel coverage while leaving out the sectors that change how the modern economy works.",
  "baikonur": "Selected because launch coverage often names Russia but leaves the site's geography, lease and sovereignty unexplained.",
  "ethnic-diversity": "Selected because international summaries regularly reduce a complex census and identity story to one majority/minority statistic.",
  "borat": "Selected because a globally famous comedy remains one of the most common reference points foreigners use when describing Kazakhstan.",
  "capital-astana": "Selected because outdated capital names still appear in search results, educational material and international reporting.",
  "yurts": "Selected because tourism imagery often turns a living heritage form into a claim about how most people live today.",
  "only-steppe": "Selected because maps and travel narratives frequently use the steppe as a visual stand-in for the country's entire geography.",
  "silk-roads": "Selected because the region's historical connectivity is often erased by modern borders and the idea of an empty interior.",
  "internet-closed": "Selected because international rankings and headlines often flatten a connected but constrained digital environment into one absolute label.",
  "secular-muslim": "Selected because public discussion often treats religious identity and constitutional secularism as mutually exclusive descriptions.",
  "nuclear-energy-weapons": "Selected because current nuclear-power debates repeatedly inherit language from the country's testing and weapons history.",
  "giant-door": "Selected because the viral image is a vivid example of how spectacular online claims can outrun authentication and local context.",
  "aral-sea-gone": "Selected because the Aral Sea is globally recognisable, yet single before/after images hide both devastation and partial recovery.",
  "landlocked-isolated": "Selected because geography explainers often equate lack of coastline with lack of trade, mobility or outside connection.",
  "kazakhstan-memes": "Selected because memes are increasingly used as evidence of national character even though they represent particular online communities and moments.",
  "horse-meat-kumys": "Selected because food stereotypes travel widely and can turn real cultural practices into assumptions about every person's daily diet.",
};
const site = Astro.site ?? new URL("https://qazaq-lens.nazkari86.workers.dev");
const articleUrl = new URL(Astro.url.pathname, site).toString();
const image = new URL(props.ogImage ?? "/og/default.png", site).toString();
  const claimReviewRating = ({ false: { ratingValue: 1, alternateName: "False" }, misleading: { ratingValue: 2, alternateName: "Misleading" }, "partly-true": { ratingValue: 3, alternateName: "Partly true" } } as Record<string, { ratingValue: number; alternateName: string }>)[props.verdict];
  const articleJsonLd = {
    "@context": "https://schema.org", "@type": "Article", headline: props.title, description: props.summary,
    image: [image], datePublished: props.publishedAt.toISOString(), dateModified: props.lastReviewedAt.toISOString(),
    author: { "@type": "Organization", name: props.author }, publisher: { "@type": "Organization", name: "Qazaq Lens", url: site.toString() },
    mainEntityOfPage: articleUrl, about: { "@type": "Country", name: "Kazakhstan" }, keywords: props.topics.join(", "),
    citation: props.sources.map((source) => source.url),
  };
  const breadcrumbJsonLd = {
    "@context": "https://schema.org", "@type": "BreadcrumbList", itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: site.toString() },
      { "@type": "ListItem", position: 2, name: "Evidence library", item: new URL("/myths", site).toString() },
      { "@type": "ListItem", position: 3, name: props.title, item: articleUrl },
    ],
  };
  const claimReviewJsonLd = {
    "@context": "https://schema.org", "@type": "ClaimReview", url: articleUrl,
    claimReviewed: props.mythStatement,
    reviewRating: { "@type": "Rating", ...claimReviewRating, bestRating: 3, worstRating: 1 },
    author: { "@type": "Organization", name: "Qazaq Lens", url: site.toString() }, itemReviewed: { "@type": "Claim", name: props.mythStatement }, datePublished: props.publishedAt.toISOString(), dateModified: props.lastReviewedAt.toISOString(), citation: props.sources.map((source) => source.url), reviewBody: props.summary,
  } as Record<string, unknown>;
  const jsonLd = [articleJsonLd, breadcrumbJsonLd, ...(claimReviewRating ? [claimReviewJsonLd] : [])];
---
<BaseLayout title={props.title} description={props.summary} ogImage={props.ogImage} type="article" noindex={props.draft} jsonLd={jsonLd}>
  <ReadingProgress />
  <article class="article-shell">
    {props.heroImage && (
      <div class="article-banner">
        <img src={props.heroImage} alt={props.heroImageAlt ?? props.title} class="article-banner-img" loading="eager" />
        {props.heroImageCredit && (
          <p class="article-banner-credit">
            {props.heroImageCreditUrl
              ? <a href={props.heroImageCreditUrl} target="_blank" rel="noopener noreferrer">{props.heroImageCredit}</a>
              : props.heroImageCredit}
          </p>
        )}
      </div>
    )}
    <header class="article-hero wrap-wide">
      <nav class="breadcrumbs" aria-label="Breadcrumb"><a href="/">Home</a><span>/</span><a href="/myths">Evidence library</a></nav>
      <div class="article-hero-grid">
        <div>
          <p class="eyebrow">Myth vs. reality</p>
          <p class="myth-quote">“{props.mythStatement}”</p>
          <h1>{props.title}</h1>
          <div class="article-actions"><ShareTools title={props.title} summary={props.summary} /><BookmarkButton slug={props.slug ?? Astro.params.slug ?? ""} title={props.title} /></div>
          <ReadingMode />
        </div>
        <VerdictBox verdict={props.verdict} summary={props.summary} publicationStatus={props.publicationStatus} />
      </div>
      {props.publicationStatus === "beta" && <aside class="notice notice--beta" aria-label="Review status"><strong>Public beta:</strong> claim-by-claim source audit completed; independent human review is still pending.</aside>}
    </header>

    <div class="article-layout wrap-wide">
      <aside class="article-sidebar"><TableOfContents headings={props.headings} /></aside>
      <div class="article-main">
        <div data-reveal data-reading-detail="summary"><KeyTakeaways items={props.keyTakeaways} /></div>
        <div data-reveal data-reading-detail="summary"><WhyThisMatters label="Why we checked this claim" text={whyWeChecked[props.slug ?? Astro.params.slug ?? ""] ?? "This topic was selected because it recurs in international discussions and can be tested against traceable evidence."} /></div>
        <div data-reveal data-reading-detail="summary"><WhyThisMatters text={whyThisMatters[props.slug ?? Astro.params.slug ?? ""] ?? "The wording matters because a memorable shortcut can shape how a real country and its people are understood."} /></div>
        <div data-reveal data-reading-detail="summary"><EvidenceVisual slug={props.slug ?? Astro.params.slug ?? ""} /></div>
        <div data-reveal data-reading-detail="summary"><EvidenceHealth myth={{ data: { sources: props.sources, lastReviewedAt: props.lastReviewedAt } } as any} /></div>
        <div data-reveal data-reading-detail="summary"><EvidenceCard title={props.title} verdict={props.verdict} summary={props.summary} slug={props.slug ?? Astro.params.slug ?? ""} /></div>
        <div class="article-body" data-reveal data-reading-detail="article"><slot /></div>
        <div data-reveal data-reading-detail="evidence"><ClaimLedger claims={props.claims} /></div>
        <div data-reveal data-reading-detail="evidence"><KnowledgeCheck claims={props.claims} /></div>
        <div data-reveal data-reading-detail="evidence"><SourceList sources={props.sources} /></div>
        <LastReviewed publishedAt={props.publishedAt} lastReviewedAt={props.lastReviewedAt} author={props.author} reviewStatus={props.reviewStatus} reviewedBy={props.reviewedBy} readingMinutes={props.readingMinutes} />
        <Changelog entries={props.changelog} />
        <ReportError pageUrl={Astro.url.pathname} />
        <Comments slug={props.slug ?? Astro.params.slug ?? ""} title={props.title} />
        <RelatedMyths entries={props.related} />
      </div>
    </div>
  </article>
  <SelectionAnnotation />
</BaseLayout>
