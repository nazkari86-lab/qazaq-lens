---
interface Props { title: string; summary: string }
const { title, summary } = Astro.props;
---
<div class="share-tools" aria-label="Article actions">
  <button class="action-button" type="button" data-share><span aria-hidden="true">↗</span> Share</button>
  <button class="action-button" type="button" data-copy-link><span aria-hidden="true">⧉</span> Copy link</button>
  <button class="action-button" type="button" data-print><span aria-hidden="true">⌑</span> Print</button>
  <span class="share-status" data-share-status role="status" aria-live="polite"></span>
</div>
<script is:inline define:vars={{ title, summary }}>
  const status = document.querySelector("[data-share-status]");
  const announce = (message) => { if (status) status.textContent = message; };
  document.querySelector("[data-share]")?.addEventListener("click", async () => {
    try {
      if (navigator.share) await navigator.share({ title, text: summary, url: location.href });
      else { await navigator.clipboard.writeText(location.href); announce("Link copied."); }
    } catch (error) {
      if (error && error.name !== "AbortError") announce("Sharing was not available.");
    }
  });
  document.querySelector("[data-copy-link]")?.addEventListener("click", async () => {
    try { await navigator.clipboard.writeText(location.href); announce("Link copied."); }
    catch { announce("Copy failed. Select the address from your browser."); }
  });
  document.querySelector("[data-print]")?.addEventListener("click", () => window.print());
</script>
