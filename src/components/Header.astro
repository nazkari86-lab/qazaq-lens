---
import Logo from "./Logo.astro";
const pathname = Astro.url.pathname;
const isCurrent = (href: string) => pathname === href || (href !== "/" && pathname.startsWith(`${href}/`));
const explore = [{ href: "/story", label: "Visual story" }, { href: "/myths", label: "Evidence library" }, { href: "/profile", label: "Country profile" }, { href: "/paths", label: "Reading paths" }, { href: "/gallery", label: "Visual archive" }];
const evidence = [{ href: "/sources", label: "Source dashboard" }, { href: "/compare", label: "Compare explainers" }, { href: "/data-status", label: "Data status" }, { href: "/glossary", label: "Glossary" }, { href: "/methodology", label: "Methodology" }];
const project = [{ href: "/about", label: "About" }, { href: "/corrections", label: "Corrections" }, { href: "/accessibility", label: "Accessibility" }, { href: "/privacy", label: "Privacy" }];
const groupCurrent = (items: { href: string }[]) => items.some((item) => isCurrent(item.href));
---
<a class="skip-link" href="#main-content">Skip to content</a>
<header class="site-header" data-header>
  <div class="wrap-wide header-inner">
    <a href="/" class="logo" aria-label="Qazaq Lens home"><Logo /></a>
    <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="primary-nav" data-nav-toggle>
      <span class="nav-toggle-label">Menu</span>
      <span class="nav-toggle-icon" aria-hidden="true"></span>
    </button>
    <nav id="primary-nav" class="primary-nav" aria-label="Primary navigation" data-nav>
      <a href="/start" aria-current={isCurrent("/start") ? "page" : undefined}>Start</a>
      <details class="nav-group" open={groupCurrent(explore)}>
        <summary class:list={[groupCurrent(explore) && "is-current"]}>Explore</summary>
        <div class="nav-dropdown">{explore.map((item) => <a class:list={[item.href === "/story" && "nav-story-link"]} href={item.href} aria-current={isCurrent(item.href) ? "page" : undefined}>{item.label}</a>)}</div>
      </details>
      <details class="nav-group" open={groupCurrent(evidence)}>
        <summary class:list={[groupCurrent(evidence) && "is-current"]}>Evidence</summary>
        <div class="nav-dropdown">{evidence.map((item) => <a href={item.href} aria-current={isCurrent(item.href) ? "page" : undefined}>{item.label}</a>)}</div>
      </details>
      <a href="/search" aria-current={isCurrent("/search") ? "page" : undefined}>Search</a>
      <details class="nav-group" open={groupCurrent(project)}>
        <summary class:list={[groupCurrent(project) && "is-current"]}>About</summary>
        <div class="nav-dropdown">{project.map((item) => <a href={item.href} aria-current={isCurrent(item.href) ? "page" : undefined}>{item.label}</a>)}</div>
      </details>
      <button class="theme-toggle" type="button" data-theme-toggle aria-label="Switch color theme">
        <span class="theme-icon" aria-hidden="true" data-theme-icon>◐</span><span class="theme-label" data-theme-label>Theme</span>
      </button>
    </nav>
  </div>
</header>
<script>
  const header = document.querySelector<HTMLElement>("[data-header]");
  const toggle = document.querySelector<HTMLButtonElement>("[data-nav-toggle]");
  const nav = document.querySelector<HTMLElement>("[data-nav]");
  const themeToggle = document.querySelector<HTMLButtonElement>("[data-theme-toggle]");

  toggle?.addEventListener("click", () => {
    const open = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!open));
    nav?.classList.toggle("is-open", !open);
  });
  nav?.querySelectorAll("a").forEach((link) => link.addEventListener("click", () => {
    toggle?.setAttribute("aria-expanded", "false");
    nav.classList.remove("is-open");
  }));

  const CYCLE: Record<string, string> = { system: "light", light: "dark", dark: "system" };
  const ICONS: Record<string, string> = { system: "◐", light: "○", dark: "●" };
  const LABELS: Record<string, string> = { system: "Auto", light: "Light", dark: "Dark" };
  const icon = document.querySelector<HTMLElement>("[data-theme-icon]");
  const label = document.querySelector<HTMLElement>("[data-theme-label]");

  const applyTheme = (theme: string) => {
    if (theme === "system") {
      delete document.documentElement.dataset.theme;
      try { localStorage.removeItem("qazaq-lens-theme"); } catch {}
    } else {
      document.documentElement.dataset.theme = theme;
      try { localStorage.setItem("qazaq-lens-theme", theme); } catch {}
    }
    if (icon) icon.textContent = ICONS[theme] ?? "◐";
    if (label) label.textContent = LABELS[theme] ?? "Theme";
  };

  const getTheme = () => {
    let saved = ""; try { saved = localStorage.getItem("qazaq-lens-theme") ?? ""; } catch {}
    if (saved === "light" || saved === "dark") return saved;
    return "system";
  };

  applyTheme(getTheme());

  themeToggle?.addEventListener("click", () => {
    const current = getTheme();
    applyTheme(CYCLE[current] ?? "system");
  });

  const onScroll = () => header?.classList.toggle("is-scrolled", window.scrollY > 8);
  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });
</script>
