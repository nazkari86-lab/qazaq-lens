---
interface Props { slug: string; title: string }
const { slug, title } = Astro.props;
---
<button class="bookmark-button action-button" type="button" data-bookmark={slug} aria-pressed="false" aria-label={`Save ${title} for later`}><span aria-hidden="true">☆</span><span data-bookmark-label>Save for later</span></button>
<script>
  const button = document.querySelector<HTMLButtonElement>("[data-bookmark]");
  if (button) {
    const slug = button.dataset.bookmark ?? "";
    const key = "qazaq-lens-bookmarks";
    const read = () => { try { return JSON.parse(localStorage.getItem(key) ?? "[]") as string[]; } catch { return []; } };
    const update = () => { const saved = read().includes(slug); button.setAttribute("aria-pressed", String(saved)); button.classList.toggle("is-saved", saved); const icon = button.querySelector<HTMLElement>("[aria-hidden]"); const label = button.querySelector<HTMLElement>("[data-bookmark-label]"); if (icon) icon.textContent = saved ? "★" : "☆"; if (label) label.textContent = saved ? "Saved" : "Save for later"; };
    update();
    button.addEventListener("click", () => { const saved = read(); const next = saved.includes(slug) ? saved.filter((item) => item !== slug) : [...saved, slug]; try { localStorage.setItem(key, JSON.stringify(next)); } catch {} update(); });
  }
</script>
