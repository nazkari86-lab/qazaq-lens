---
interface Props { explainerCount: number; sourceCount: number }
const { explainerCount, sourceCount } = Astro.props;
---
<div class="ql-banner" aria-label="Qazaq Lens visual introduction">
  <div class="ql-banner-map"><img src="/maps-kazakhstan.svg" alt="Map of Kazakhstan showing the country at the centre of the evidence project" /></div>
  <div class="ql-banner-photo ql-banner-photo--one"><img src="/heroes/baiterek.jpg" alt="Baiterek tower in Astana" loading="eager" /></div>
  <div class="ql-banner-photo ql-banner-photo--two"><img src="/heroes/baikonur-real.jpg" alt="A real launch at Baikonur in Kazakhstan" loading="lazy" /></div>
  <div class="ql-banner-photo ql-banner-photo--three"><img src="/heroes/charyn-canyon.jpg" alt="Charyn Canyon in Kazakhstan" loading="lazy" /></div>
  <div class="ql-banner-scan" aria-hidden="true"></div>
  <div class="ql-banner-stamp">QAZAQ<br />LENS</div>
  <div class="ql-banner-center"><span>THE COUNTRY</span><strong>behind<br />the shortcut</strong><small>{explainerCount} explainers · {sourceCount} sources · one closer look</small></div>
  <div class="ql-banner-tags" aria-hidden="true"><span>“part of Russia”</span><span>“only steppe”</span><span>“just oil”</span><span>“Borat”</span><span>“everyone lives in yurts”</span></div>
  <div class="ql-banner-footer"><span>MYTH</span><i></i><span>CONTEXT</span><i></i><span>EVIDENCE</span></div>
</div>
