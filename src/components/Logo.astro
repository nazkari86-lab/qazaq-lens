    <circle cx="22" cy="22" r="8" fill="none" stroke="currentColor" stroke-width="2" />
    <path d="M22 4v7M22 33v7M4 22h7M33 22h7M9.3 9.3l5 5M29.7 29.7l5 5M34.7 9.3l-5 5M14.3 29.7l-5 5" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
