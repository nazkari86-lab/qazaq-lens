<div class="reading-mode" data-reading-mode aria-label="Reading mode">
  <span class="reading-mode-label">Read as</span>
  <button type="button" class="reading-mode-button is-active" data-mode="deep" aria-pressed="true">Deep evidence</button>
  <button type="button" class="reading-mode-button" data-mode="quick" aria-pressed="false">Quick summary</button>
</div>
<script>
  const control = document.querySelector<HTMLElement>("[data-reading-mode]");
  const article = document.querySelector<HTMLElement>(".article-shell");
  if (control && article) {
    const key = "qazaq-lens-reading-mode";
    const buttons = [...control.querySelectorAll<HTMLButtonElement>("[data-mode]")];
    const apply = (mode: string) => { const value = mode === "quick" ? "quick" : "deep"; article.classList.toggle("is-quick-reading", value === "quick"); buttons.forEach((button) => { const active = button.dataset.mode === value; button.classList.toggle("is-active", active); button.setAttribute("aria-pressed", String(active)); }); try { localStorage.setItem(key, value); } catch {} };
    let initial = "deep"; try { initial = localStorage.getItem(key) ?? "deep"; } catch {}
    apply(initial); buttons.forEach((button) => button.addEventListener("click", () => apply(button.dataset.mode ?? "deep")));
  }
</script>
